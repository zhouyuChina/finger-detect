    "t-tag": "miniprogram_npm/tag/tag",
    "t-divider": "miniprogram_npm/divider/divider",
    "t-empty": "miniprogram_npm/empty/empty",
    "t-loading": "miniprogram_npm/loading/loading",
    "t-toast": "miniprogram_npm/toast/toast",
    "t-message": "miniprogram_npm/message/message",
    "t-grid": "miniprogram_npm/grid/grid",
    "t-grid-item": "miniprogram_npm/grid-item/grid-item",
    "t-tabs": "miniprogram_npm/tabs/tabs",
    "t-tab-panel": "miniprogram_npm/tab-panel/tab-panel",
    "t-search": "miniprogram_npm/search/search",
