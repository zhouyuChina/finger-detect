      "Bash(else echo \"  ✗ $component - 缺失\")",
      "Bash(fi)",
      "Bash(done)",
      "Bash(./scripts/build-npm.sh:*)",
      "Bash(./build-npm.sh)",
      "Bash(ln:*)",
      "Bash(git rm:*)",
      "Bash(git log:*)",
      "Bash(cat:*)",
      "Bash(python3:*)"
