<!--my-profile.wxml-->
<view class="container">

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-section">
    <t-search 
      placeholder="搜索用户姓名或档案ID" 
      bind:submit="onSearch"
      bind:change="onSearchChange"
      value="{{searchValue}}"
      center
    />
  </view>


  <!-- 档案列表 -->
  <view class="profile-list" wx:if="{{filteredProfiles.length > 0}}">
    <t-cell-group>
      <t-cell 
        wx:for="{{filteredProfiles}}" 
        wx:key="id"
        bindtap="onProfileClick"
        data-id="{{item.id}}"
        hover
        arrow
      >
        <view slot="left-icon" class="cell-avatar">
          <t-avatar 
            image="{{item.avatar}}" 
            size="medium"
          />
        </view>
        
        <view slot="title" class="cell-title">
          <view class="profile-name">{{item.name}}</view>
          <view class="profile-details">
            <text class="detail-item">{{item.gender}} | {{item.age}}岁</text>
            <text class="detail-item">{{item.relationship}}</text>
          </view>
        </view>
        
        <view slot="description" class="cell-description">
          <view class="profile-meta">
            <text class="meta-item">档案ID: {{item.profileId}}</text>
            <text class="meta-item">更新时间: {{item.updateTime}}</text>
            <text class="meta-item">档案: {{item.archives}} | 照片: {{item.photos}} | 报告: {{item.reports}}</text>
          </view>
        </view>
        
        <view slot="note" class="cell-actions">
          <view class="action-buttons">
            <t-button 
              size="small" 
              theme="light" 
              variant="outline"
              bindtap="onEditProfile" 
              data-id="{{item.id}}"
              catchtap="onEditProfile"
            >
              编辑
            </t-button>
            <t-button 
              size="small" 
              theme="danger" 
              variant="outline"
              bindtap="onDeleteProfile" 
              data-id="{{item.id}}"
              catchtap="onDeleteProfile"
            >
              删除
            </t-button>
          </view>
        </view>
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 空状态 -->
  <t-empty 
    wx:if="{{!loading && filteredProfiles.length === 0}}"
    description="暂无档案记录"
    icon="user-avatar"
  >
    <t-button 
      slot="action" 
      theme="primary" 
      size="medium"
      bindtap="onAddProfile"
    >
      添加档案
    </t-button>
  </t-empty>

  <!-- 编辑档案弹窗 -->
  <t-popup 
    visible="{{showEditPopup}}" 
    placement="center" 
    bind:visible-change="onEditPopupChange"
    close-on-overlay-click="{{false}}"
  >
    <view class="edit-popup">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <text class="popup-title">编辑当前档案信息</text>
        <text class="popup-close" bindtap="closeEditPopup">×</text>
      </view>

      <!-- 编辑表单 -->
      <view class="edit-form">
        <t-cell-group>
          <!-- 姓名 -->
          <t-cell 
            title="姓名" 
            description="{{editingProfile.name}}" 
            arrow 
            hover
            bindtap="editName"
          />
          
          <!-- 性别 -->
          <t-cell 
            title="性别" 
            description="{{editingProfile.gender}}" 
            arrow 
            hover
            bindtap="editGender"
          />
          
          <!-- 年龄 -->
          <t-cell 
            title="设置年龄" 
            description="{{editingProfile.age}}" 
            arrow 
            hover
            bindtap="editAge"
          />
          
          <!-- 地址 -->
          <t-cell 
            title="地址" 
            description="{{editingProfile.address}}" 
            arrow 
            hover
            bindtap="editAddress"
          />
        </t-cell-group>
      </view>

      <!-- 操作按钮 -->
      <view class="popup-actions">
        <t-button 
          theme="light" 
          size="small"
          bindtap="closeEditPopup"
        >
          取消
        </t-button>
        <t-button 
          theme="primary" 
          size="small"
          bindtap="saveProfile"
        >
          保存
        </t-button>
      </view>
    </view>
  </t-popup>
</view> 