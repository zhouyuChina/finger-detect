/* my-profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  justify-content: start;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #2B81E8, #1E88E5);
  padding: 60rpx 40rpx 40rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(180deg); }
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 搜索栏 */
.search-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
  width: calc(100vw - 60rpx);
  margin: 10rpx 0;
}

/* 统计信息卡片 */
.stats-section {
  padding: 0 40rpx 20rpx;
}

.stats-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stats-item {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: center;
  gap: 20rpx;
}

.stats-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(43, 129, 232, 0.1);
}

.stats-item:nth-child(2) .stats-icon {
  background: rgba(0, 168, 112, 0.1);
}

.stats-item:nth-child(3) .stats-icon {
  background: rgba(255, 152, 0, 0.1);
}

.stats-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.stats-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

/* 档案列表 */
.profile-list {
  margin-bottom: 20rpx;
}

.cell-avatar {
  margin-right: 20rpx;
}

.cell-title {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.profile-details {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.detail-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.2;
}

.cell-description {
  margin-top: 8rpx;
}

.profile-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

.cell-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.action-buttons {
  display: flex;
  width: 180rpx;
  gap: 12rpx;
}

.profile-status {
  display: flex;
  justify-content: flex-end;
}

/* 添加档案按钮 */
.add-profile-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 空状态样式 */
.t-empty {
  margin-top: 100rpx;
}

.cell-actions {
  width: 200rpx;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .profile-details {
    flex-direction: column;
    gap: 4rpx;
  }
  
  .action-buttons {
    flex-direction: column;
    gap: 8rpx;
  }
}

/* 编辑弹窗样式 */
.edit-popup {
  width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.popup-close:active {
  background-color: #e0e0e0;
}

.edit-form {
  max-height: 60vh;
  overflow-y: auto;
}

.popup-actions {
  display: flex;
  gap: 20rpx;
  padding: 40rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-actions .t-button {
  flex: 1;
}

/* 弹窗内cell样式优化 */
.edit-form .t-cell {
  background-color: #fff;
}

.edit-form .t-cell__title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.edit-form .t-cell__description {
  font-size: 28rpx;
  color: #999;
}

.edit-form .t-cell__arrow {
  color: #ccc;
}