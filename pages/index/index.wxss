/* index.wxss */
page {
  background-color: #f2fef9;
}

.container {
  padding: 0rpx;
}

/* 轮播图区域 */
.banner {
  /* margin: 30rpx 30rpx 30rpx 30rpx; */
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
  width: 100vw;
  border-radius: 24rpx;
}

.banner-swiper {
  height: 60vh;
  width: 100%;
  border-radius: 24rpx;
}

.banner-item {
  height: 60vh;
  display: flex;
  /* flex-direction: column;
  align-items: center;
  justify-content: center; */
  background: #f5f5f5;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

/* 背景图片 */
.banner-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.middle-float {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  bottom: 60rpx;
}

/* 毛玻璃卡片 */
.banner-card {
  /* position: absolute; */
  z-index: 2;
  background: rgba(255, 255, 255, .9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  /* padding: 60rpx 80rpx; */
  border-radius: 32rpx;
  text-align: center;
  /* box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1); */
  /* margin: 0 40rpx; */
  width: 90vw;
  height: 300rpx;
  opacity: .9;
  border: 1px solid rgba(255,255,255,.35);
  background:
  /* 顶部到右上角的“泛光”渐变，可按需调 */
  radial-gradient(120% 120% at 80% 0%,
    rgba(255,255,255,.25) 0%,
    rgba(255,255,255,0) 60%) ,
    rgba(255,255,255,.18);                 /* 半透明底色 */
  box-shadow: 0 12px 40px rgba(0,0,0,.18);

  /* 关键：对“背后”内容进行模糊和轻微饱和 */
  backdrop-filter: blur(16px) saturate(120%);
}

/* 主要功能区域 */
.main-actions {
  position: fixed;
  text-align: center;
  border-radius: 16rpx;
  width: 100vw;
  z-index: 20;
  bottom: 0rpx;
  /* left: 5vw; */
  /* bottom: 24rpx; */
  background: #fff;
  padding: 24rpx 0;
}

.banner-content {
  position: relative;
  z-index: 2;
  padding: 0 40rpx;
  text-align: center;
}

.banner-text {
  text-align: center;
  position: absolute;
  bottom: 124rpx;
  left: 50%;
  transform: translateX(-50%);
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 20rpx;
  color: #fff;
  letter-spacing: 2rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.8;
  display: block;
  color: #fff;
  line-height: 1.6;
}

.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.photo-btn {
  width: 80vw !important;
  background: linear-gradient(135deg, #00BC7D, #00BC7D);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
  margin-bottom: 0rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 10px 24px;
}

.photo-btn::after {
  border: none;
}

.btn-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* 消息区域 */
.message-section {
  background-color: #fff;
  border-radius: 0rpx;
  padding: 30rpx;
  margin: 0;
  box-shadow: none;
  width: calc(100vw - 60rpx);
  margin-bottom: 90rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.unread-count {
  font-size: 24rpx;
  color: #ff4757;
  background-color: #ffe0e0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.view-all {
  font-size: 28rpx;
  color: #00BC7D;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: auto;
}

.message-item {
  display: flex;
  padding: 24rpx 0;
  width: calc(100vw - 69rpx);
  height: 74rpx;
  /* border-bottom: 1rpx solid #f0f0f0; */
  /* border: 1px solid #333; */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
  position: relative;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.message-item:last-child {
  border-bottom: none;
}

/* 消息项样式 */
.message-item.unread {
  background-color: #f8f9ff;
}

.message-item.top {
  border-left: 4rpx solid #00BC7D;
}

.message-item.important {
  border-left: 4rpx solid #ff4757;
}

.message-item.top.important {
  border-left: 4rpx solid #00BC7D;
}

/* 置顶图标 */
.top-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  color: #00BC7D;
  font-size: 20rpx;
  z-index: 10;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 消息封面图片 */
.message-cover {
  position: relative;
  margin-right: 20rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
  width: 120rpx;
  height: 80rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 消息图标（无封面图片时显示） */
.message-icon {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-bg {
  width: 120rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
  margin-left: 20rpx;
}

.icon-bg.tech {
  background-color: #E8F5E9;
}

.icon-bg.health {
  background-color: #E8F5E9;
}

.icon-bg.news {
  background-color: #E8F5E9;
}

.icon-text {
  font-size: 24rpx;
}

.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 8rpx;
  border: 2rpx solid white;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.message-title-row {
  display: flex;
  align-items: flex-start;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.title-container {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 16rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  line-height: 1.4;
  margin-right: 64rpx;
  margin-top: 16rpx;
}

.top-icon {
  margin-left: 8rpx;
  flex-shrink: 0;
}

.top-icon-text {
  font-size: 24rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.message-summary {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.message-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
  flex-wrap: wrap;
  align-items: center;
}

.message-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

/* 标签样式 */
.top-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #00BC7D;
  color: white;
}

.important-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #ff4757;
  color: white;
}

.category-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #f0f0f0;
  color: #666;
}

.read-count {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: transparent;
  color: #999;
}

/* 作者信息 */
.message-author {
  margin-top: 4rpx;
}

.author-text {
  font-size: 22rpx;
  color: #999;
}

/* 爱心收藏图标 */
.favorite-icon {
  display: flex;
  align-items: flex-start;
  padding-top: 8rpx;
  margin-left: 16rpx;
}

/* 快捷功能区域 */
.quick-functions {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  min-height: 120rpx;
  justify-content: center;
}

.grid-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* 授权弹窗样式 */
.auth-popup-content {
  background: #fff;
  padding: 48rpx 40rpx 60rpx;
  border-radius: 32rpx 32rpx 0 0;
  text-align: center;
}

.auth-popup-header {
  margin-bottom: 40rpx;
}

.auth-icon-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.auth-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.auth-popup-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.auth-popup-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.auth-description {
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.auth-actions {
  margin-bottom: 32rpx;
  padding: 0 20rpx;
}
