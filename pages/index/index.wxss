/* index.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  padding: 0rpx;
}

/* 轮播图区域 */
.banner {
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  width: 100vw;
}

.banner-swiper {
  height: 600rpx;
  width: 100vw;
}

.banner-item {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.banner-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: white;
  padding: 0 40rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}



/* 主要功能区域 */
.main-actions {
  text-align: center;
  border-radius: 16rpx;
  margin: 0 20rpx 30rpx 20rpx;
}

.photo-btn {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
  margin-bottom: 0rpx;
}

.photo-btn::after {
  border: none;
}

.action-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* 消息区域 */
.message-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  /* margin: 0 20rpx 30rpx 20rpx; */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.unread-count {
  font-size: 24rpx;
  color: #ff4757;
  background-color: #ffe0e0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.view-all {
  font-size: 28rpx;
  color: #4CAF50;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: auto;
}

.message-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.message-item:last-child {
  border-bottom: none;
}

.message-item.unread {
  background-color: #f8f9ff;
}

.message-icon {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-bg {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.icon-bg.system {
  background-color: #ff4757;
}

.icon-bg.notice {
  background-color: #4CAF50;
}

.icon-bg.tip {
  background-color: #ffa726;
}

.icon-text {
  font-size: 24rpx;
}

.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 8rpx;
  border: 2rpx solid white;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.message-body {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.priority-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: white;
}

.priority-tag.high {
  background-color: #ff4757;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  color: #666;
}

/* 快捷功能区域 */
.quick-functions {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  min-height: 120rpx;
  justify-content: center;
}

.grid-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
} 