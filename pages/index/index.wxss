/* index.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  padding: 0rpx;
}

/* 轮播图区域 */
.banner {
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  width: 100vw;
}

.banner-swiper {
  height: 600rpx;
  width: 100vw;
}

.banner-item {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.banner-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: white;
  padding: 0 40rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}



/* 主要功能区域 */
.main-actions {
  text-align: center;
  border-radius: 16rpx;
  margin: 0 20rpx 30rpx 20rpx;
}

.photo-btn {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
  margin-bottom: 0rpx;
}

.photo-btn::after {
  border: none;
}

.action-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* 消息区域 */
.message-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  /* margin: 0 20rpx 30rpx 20rpx; */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.unread-count {
  font-size: 24rpx;
  color: #ff4757;
  background-color: #ffe0e0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.view-all {
  font-size: 28rpx;
  color: #4CAF50;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: auto;
}

.message-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.message-item:last-child {
  border-bottom: none;
}

/* 消息项样式 */
.message-item.unread {
  background-color: #f8f9ff;
}

.message-item.top {
  border-left: 4rpx solid #ff6b35;
}

.message-item.important {
  border-left: 4rpx solid #ff4757;
}

.message-item.top.important {
  border-left: 4rpx solid #ff6b35;
}

/* 消息封面图片 */
.message-cover {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 120rpx;
  height: 80rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 消息图标（无封面图片时显示） */
.message-icon {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-bg {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.icon-bg.tech {
  background-color: #2196F3;
}

.icon-bg.health {
  background-color: #4CAF50;
}

.icon-bg.news {
  background-color: #ffa726;
}

.icon-text {
  font-size: 24rpx;
}

.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 8rpx;
  border: 2rpx solid white;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.message-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

/* 标签样式 */
.top-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #ff6b35;
  color: white;
}

.important-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #ff4757;
  color: white;
}

.category-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #f0f0f0;
  color: #666;
}

.read-count {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #e3f2fd;
  color: #1976d2;
}

/* 作者信息 */
.message-author {
  margin-top: 4rpx;
}

.author-text {
  font-size: 22rpx;
  color: #999;
}

/* 快捷功能区域 */
.quick-functions {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  min-height: 120rpx;
  justify-content: center;
}

.grid-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* 调试区域样式 */
.debug-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 30rpx;
  z-index: 1000;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.debug-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.debug-close {
  font-size: 28rpx;
  color: #666;
  padding: 10rpx;
}

.debug-content {
  margin-bottom: 20rpx;
}

.debug-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.debug-label {
  font-size: 28rpx;
  color: #666;
}

.debug-value {
  font-size: 28rpx;
  color: #333;
  max-width: 400rpx;
  text-align: right;
  word-break: break-all;
}

.debug-value.success {
  color: #4CAF50;
}

.debug-value.error {
  color: #f44336;
}

.debug-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.debug-btn {
  flex: 1;
  min-width: 150rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  background: #007AFF;
  color: #fff;
  border: none;
  border-radius: 8rpx;
}

.debug-toggle {
  position: fixed;
  bottom: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: #007AFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 122, 255, 0.3);
  z-index: 999;
}

.debug-toggle-text {
  font-size: 32rpx;
  color: #fff;
} 