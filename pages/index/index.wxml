<!--index.wxml-->
<view class="container">
  <!-- 轮播图区域 -->
  <view class="banner" wx:if="{{bannerList && bannerList.length > 0}}">
    <swiper class="banner-swiper" indicator-dots="{{bannerConfig.indicatorDots}}" autoplay="{{bannerConfig.autoplay}}" interval="{{bannerConfig.interval}}" circular="{{bannerConfig.circular}}">
      <view class="middle-float">
        <!-- 毛玻璃卡片 -->
        <!-- <view class="banner-card"></view>

        <view class="banner-text">
          <text class="banner-title">月芽康专业检测</text>
          <text class="banner-desc">灰指甲AI智能识别系统</text>
        </view> -->
      </view>
      <swiper-item wx:for="{{bannerList}}" wx:key="id">
        <view class="banner-item" bindtap="onBannerTap" data-index="{{index}}">
          <!-- 背景图片 -->
          <image wx:if="{{item.imageUrl}}" class="banner-bg-image" src="{{item.imageUrl}}" mode="aspectFill" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 主要功能区域 -->
  <view class="main-actions">
    <button class="photo-btn" bindtap="onPhotoDetection">
      <t-icon name="camera" size="40rpx" color="white" class="btn-icon" />
      开始检测
    </button>
  </view>

  <!-- 消息列表 -->
  <view class="message-section" wx:if="{{messages.length > 0}}">
    <view class="section-header">
      <text class="section-title">健康资讯</text>
      <view class="header-actions">
        <text class="view-all" bindtap="onViewAll">全部已读</text>
      </view>
    </view>

    <view class="message-list">
      <view class="message-item {{item.isRead ? 'read' : 'unread'}} {{item.isTop ? 'top' : ''}} {{item.isImportant ? 'important' : ''}}" wx:for="{{messages}}" wx:key="id" bindtap="onMessageTap" data-index="{{index}}">
        <!-- 置顶图标 -->
        <view class="top-badge" wx:if="{{item.isTop}}">
          置顶
        </view>

        <!-- 消息封面图片 -->
        <view class="message-cover" wx:if="{{item.coverImage}}">
          <image class="cover-image" src="{{item.coverImage}}" mode="aspectFill" />
          <!-- 未读红点 -->
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>

        <!-- 消息图标（无封面图片时显示） -->
        <view class="message-icon" wx:if="{{!item.coverImage}}">
          <view class="icon-bg {{item.category === '技术资讯' ? 'tech' : item.category === '健康提醒' ? 'health' : 'news'}}">
            <t-icon name="file-copy" size="40rpx" color="#00BC7D" />
          </view>
          <!-- 未读红点 -->
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>

        <view class="message-content">
          <view class="message-title-row">
            <text class="message-title">{{item.title}}</text>
          </view>
          <!-- <text class="message-summary">{{item.summary}}</text> -->

          <!-- 消息标签和元信息 -->
        </view>

      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{bannerList.length === 0 && messages.length === 0 && !loading}}">
    <view class="empty-icon">📱</view>
    <text class="empty-text">暂无数据</text>
    <text class="empty-desc">请稍后再试或检查网络连接</text>
  </view>

  <!-- 授权弹窗 - 底部弹出 -->
  <t-popup
    visible="{{showAuthPopup}}"
    placement="bottom"
    close-on-overlay-click="{{false}}"
  >
    <view class="auth-popup-content">
      <!-- 弹窗头部 -->
      <view class="auth-popup-header">
        <view class="auth-icon-wrapper">
          <image class="auth-logo" src="/images/logo.png" mode="aspectFit"></image>
        </view>
        <text class="auth-popup-title">欢迎使用</text>
        <text class="auth-popup-subtitle">手指专业检测</text>
      </view>

      <!-- 授权说明 -->
      <!-- <view class="auth-description">
        <text class="desc-text">点击开始使用，后续将完善您的个人信息</text>
      </view> -->

      <!-- 授权按钮 -->
      <view class="auth-actions">
        <t-button
          theme="primary"
          size="large"
          block
          bindtap="handleAuth"
          loading="{{authLoading}}"
          disabled="{{authLoading}}"
          style="background: linear-gradient(135deg, #009966 0%, #00BC7D 100%);"
        >
          {{authLoading ? '注册中...' : '开始使用'}}
        </t-button>
      </view>
    </view>
  </t-popup>

</view>