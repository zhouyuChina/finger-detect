<!--index.wxml-->
<view class="container">
  <!-- 轮播图区域 -->
  <view class="banner" wx:if="{{bannerList && bannerList.length > 0}}">
    <swiper 
      class="banner-swiper" 
      indicator-dots="{{bannerConfig.indicatorDots}}"
      autoplay="{{bannerConfig.autoplay}}"
      interval="{{bannerConfig.interval}}"
      circular="{{bannerConfig.circular}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="rgba(255, 255, 255, 0.8)"
    >
      <swiper-item wx:for="{{bannerList}}" wx:key="id">
        <view 
          class="banner-item" 
          style="background: {{item.background}}"
          bindtap="onBannerTap"
          data-index="{{index}}"
        >
          <view class="banner-content">
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-desc">{{item.desc}}</text>
          </view>
          <!-- 如果有图片，显示图片 -->
          <image 
            wx:if="{{item.imageUrl}}" 
            class="banner-image" 
            src="{{item.imageUrl}}" 
            mode="aspectFill"
          />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 调试用测试banner -->
  <view class="banner" wx:if="{{!bannerList || bannerList.length === 0}}">
    <view class="banner-swiper">
      <view class="banner-item" style="background: linear-gradient(135deg, #4CAF50, #45a049);">
        <view class="banner-content">
          <text class="banner-title">测试Banner</text>
          <text class="banner-desc">这是一个测试banner，用于调试显示问题</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 主要功能区域 -->
  <view class="main-actions">
    <button 
      class="photo-btn"
      bindtap="onPhotoDetection"
    >
      拍照检测
    </button>
    <!-- <text class="action-desc">早检测，早知道</text> -->
  </view>

  <!-- 消息列表 -->
  <view class="message-section" wx:if="{{messages.length > 0}}">
    <view class="section-header">
      <text class="section-title">置顶资讯</text>
      <view class="header-actions">
        <text class="unread-count" wx:if="{{unreadCount > 0}}">{{unreadCount}}条未读</text>
        <text class="view-all" bindtap="onViewAll">查看全部</text>
      </view>
    </view>
    
    <view class="message-list">
      <view 
        class="message-item {{item.isRead ? 'read' : 'unread'}} {{item.isTop ? 'top' : ''}} {{item.isImportant ? 'important' : ''}}"
        wx:for="{{messages}}" 
        wx:key="id"
        bindtap="onMessageTap"
        data-index="{{index}}"
      >
        <!-- 消息封面图片 -->
        <view class="message-cover" wx:if="{{item.coverImage}}">
          <image 
            class="cover-image" 
            src="{{item.coverImage}}" 
            mode="aspectFill"
          />
          <!-- 未读红点 -->
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>
        
        <!-- 消息图标（无封面图片时显示） -->
        <view class="message-icon" wx:if="{{!item.coverImage}}">
          <view class="icon-bg {{item.category === '技术资讯' ? 'tech' : item.category === '健康提醒' ? 'health' : 'news'}}">
            <text class="icon-text">{{item.category === '技术资讯' ? '技' : item.category === '健康提醒' ? '健' : '资'}}</text>
          </view>
          <!-- 未读红点 -->
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>
        
        <view class="message-content">
          <view class="message-header">
            <view class="title-container">
              <text class="message-title">{{item.title}}</text>
              <!-- 置顶图标 -->
              <view class="top-icon" wx:if="{{item.isTop}}">
                <text class="top-icon-text">📌</text>
              </view>
            </view>
            <text class="message-time">{{item.publishTime}}</text>
          </view>
          <text class="message-summary">{{item.summary}}</text>
          
          <!-- 消息标签 -->
          <view class="message-tags">
            <!-- 置顶标签 -->
            <text class="top-tag" wx:if="{{item.isTop}}">置顶</text>
            <!-- 重要标签 -->
            <text class="important-tag" wx:if="{{item.isImportant}}">重要</text>
            <!-- 分类标签 -->
            <text class="category-tag">{{item.category}}</text>
            <!-- 阅读数 -->
            <text class="read-count" wx:if="{{item.readCount > 0}}">{{item.readCount}}阅读</text>
          </view>
          
          <!-- 作者信息 -->
          <view class="message-author" wx:if="{{item.author}}">
            <text class="author-text">作者：{{item.author}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{bannerList.length === 0 && messages.length === 0 && !loading}}">
    <view class="empty-icon">📱</view>
    <text class="empty-text">暂无数据</text>
    <text class="empty-desc">请稍后再试或检查网络连接</text>
  </view>

  <!-- 调试区域 -->
  <view class="debug-section" wx:if="{{showDebug}}">
    <view class="debug-header">
      <text class="debug-title">🔧 环境调试</text>
      <text class="debug-close" bindtap="toggleDebug">关闭</text>
    </view>
    
    <view class="debug-content">
      <view class="debug-item">
        <text class="debug-label">当前环境:</text>
        <text class="debug-value">{{currentEnv.name}}</text>
      </view>
      <view class="debug-item">
        <text class="debug-label">API地址:</text>
        <text class="debug-value">{{currentEnv.apiUrl}}</text>
      </view>
      <view class="debug-item">
        <text class="debug-label">连接状态:</text>
        <text class="debug-value {{connectionStatus.success ? 'success' : 'error'}}">
          {{connectionStatus.success ? '✅ 正常' : '❌ 异常'}}
        </text>
      </view>
    </view>
    
    <view class="debug-actions">
      <button class="debug-btn" bindtap="testConnection">测试连接</button>
      <button class="debug-btn" bindtap="switchToLocal">切换到本地</button>
      <button class="debug-btn" bindtap="switchToTest">切换到测试</button>
      <button class="debug-btn" bindtap="compareEnvs">对比环境</button>
      <button class="debug-btn" bindtap="compareApis">对比接口</button>
      <button class="debug-btn" bindtap="testDataFormats">测试数据格式</button>
    </view>
  </view>

  <!-- 调试按钮 -->
  <view class="debug-toggle" bindtap="toggleDebug">
    <text class="debug-toggle-text">🔧</text>
  </view>
</view> 