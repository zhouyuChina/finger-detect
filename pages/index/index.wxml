<!--index.wxml-->
<view class="container">
  <!-- 轮播图区域 -->
  <view class="banner" wx:if="{{bannerList && bannerList.length > 0}}">
    <swiper 
      class="banner-swiper" 
      indicator-dots="{{bannerConfig.indicatorDots}}"
      autoplay="{{bannerConfig.autoplay}}"
      interval="{{bannerConfig.interval}}"
      circular="{{bannerConfig.circular}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="rgba(255, 255, 255, 0.8)"
    >
      <swiper-item wx:for="{{bannerList}}" wx:key="id">
        <view 
          class="banner-item" 
          style="background: {{item.background}}"
          bindtap="onBannerTap"
          data-index="{{index}}"
        >
          <view class="banner-content">
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-desc">{{item.desc}}</text>
          </view>
          <!-- 如果有图片，显示图片 -->
          <image 
            wx:if="{{item.imageUrl}}" 
            class="banner-image" 
            src="{{item.imageUrl}}" 
            mode="aspectFill"
          />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 调试用测试banner -->
  <view class="banner" wx:if="{{!bannerList || bannerList.length === 0}}">
    <view class="banner-swiper">
      <view class="banner-item" style="background: linear-gradient(135deg, #4CAF50, #45a049);">
        <view class="banner-content">
          <text class="banner-title">测试Banner</text>
          <text class="banner-desc">这是一个测试banner，用于调试显示问题</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 主要功能区域 -->
  <view class="main-actions">
    <button 
      class="photo-btn"
      bindtap="onPhotoDetection"
    >
      拍照检测
    </button>
    <!-- <text class="action-desc">早检测，早知道</text> -->
  </view>

  <!-- 消息列表 -->
  <view class="message-section" wx:if="{{messages.length > 0}}">
    <view class="section-header">
      <text class="section-title">健康资讯</text>
      <view class="header-actions">
        <text class="unread-count" wx:if="{{unreadCount > 0}}">{{unreadCount}}条未读</text>
        <text class="view-all" bindtap="onViewAll">查看全部</text>
      </view>
    </view>
    
    <view class="message-list">
      <view 
        class="message-item {{item.isRead ? 'read' : 'unread'}}"
        wx:for="{{messages}}" 
        wx:key="id"
        bindtap="onMessageTap"
        data-index="{{index}}"
      >
        <view class="message-icon">
          <view class="icon-bg {{item.type}}">
            <text class="icon-text">{{item.type === 'system' ? '系' : item.type === 'notice' ? '通' : '贴'}}</text>
          </view>
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>
        
        <view class="message-content">
          <view class="message-header">
            <text class="message-title">{{item.title}}</text>
            <text class="message-time">{{item.time}}</text>
          </view>
          <text class="message-body">{{item.content}}</text>
          <view class="message-tags">
            <text class="priority-tag {{item.priority}}" wx:if="{{item.priority === 'high'}}">重要</text>
            <text class="type-tag">{{item.type === 'system' ? '系统' : item.type === 'notice' ? '通知' : '小贴士'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{bannerList.length === 0 && messages.length === 0 && !loading}}">
    <view class="empty-icon">📱</view>
    <text class="empty-text">暂无数据</text>
    <text class="empty-desc">请稍后再试或检查网络连接</text>
  </view>
</view> 