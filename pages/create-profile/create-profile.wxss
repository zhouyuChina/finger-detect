/* create-profile.wxss */
page {
  background-color: #f2fef9;
}

/* 测试按钮 */
.test-button {
  position: fixed;
  top: 100rpx;
  right: 30rpx;
  background-color: #ff4757;
  color: white;
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  z-index: 9999;
  font-size: 28rpx;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  width: calc(100vw - 60rpx);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
  border: 2rpx solid #e0e0e0;
  /* 优化移动端emoji显示清晰度 */
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
  filter: contrast(1.05) saturate(1.05);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.step-item.active .step-icon {
  background-color: #00BC7D;
  border-color: #00BC7D;
  color: #ffffff;
}

.step-title {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  transition: all 0.3s ease;
}

.step-item.active .step-title {
  color: #00BC7D;
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 40rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background-color: #e0e0e0;
  z-index: 1;
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 40rpx 30rpx;
  width: calc(100vw - 40rpx);
}

.step-content {
  height: 100%;
}

.section-title {
  font-size: 36rpx;
  color: #333;
  margin-bottom: 30rpx;
}

/* 未登录用户欢迎信息 */
.welcome-message {
  text-align: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.1);
}

.welcome-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 用户选择区域 */
.user-selection-area {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  text-align: center;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.retry-btn {
  padding: 20rpx 40rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.selection-placeholder {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  transition: background-color 0.3s ease;
  border: 1px solid #00BC7D;
  border-radius: 12rpx;
}

.selection-placeholder:active {
  background-color: #f8f9fa;
}

.placeholder-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 用户选择器弹窗 */
.user-selector-content {
  background-color: #ffffff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 0;
  max-height: 70vh; /* 修改为70vh */
  min-height: 60vh; /* 添加最小高度 */
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f8f8f8;
}

.selector-cancel {
  font-size: 32rpx;
  color: #666;
  padding: 10rpx;
}

.selector-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.selector-confirm {
  font-size: 32rpx;
  color: #00BC7D;
  font-weight: 500;
  padding: 10rpx;
}

.selector-options {
  padding: 0;
  max-height: 50vh; /* 增加选项区域的高度 */
  overflow-y: auto;
  flex: 1; /* 让选项区域占据剩余空间 */
}

.selector-option {
  /* padding: 20rpx; */
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx; /* 确保选项有足够的高度 */
  line-height: 0;
}

.selector-option:last-child {
  border-bottom: none;
}

.selector-option:active {
  background-color: #f5f5f5;
}

.option-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx; /* 确保文字区域有足够高度 */
}

.option-check {
  font-size: 32rpx;
  color: #00BC7D;
  margin-left: 20rpx;
  flex-shrink: 0;
  font-weight: bold;
  position: absolute;
  right: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx; /* 确保复选框垂直居中 */
}

.selector-option.selected {
  background-color: #f8f9fa;
  /* border-left: 4rpx solid #28a745; */
}

.selector-option.selected .option-text {
  color: #00BC7D;
  font-weight: 500;
}

/* 默认用户样式 */
.selector-option.default-user {
  position: relative;
}

.default-badge {
  font-size: 24rpx;
  color: #666;
  font-weight: 400;
  margin-left: 10rpx;
}

/* 新增用户样式 - 更突出的高亮 */
.add-option {
  /* background-color: #e3f2fd; */
  /* border: 2rpx solid #2196F3; */
  border-radius: 8rpx;
  /* margin: 10rpx 20rpx; */
}

.add-option .option-text {
  font-size: 32rpx;
  flex: 1;
  text-align: center;
}

/* 表单中的选择器样式 */
.form-content .selection-placeholder {
  background-color: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 10rpx;
}

.form-content .placeholder-text {
  color: #333;
  font-size: 28rpx;
}

.form-content .placeholder-text:empty::before {
  content: '请选择';
  color: #999;
}

