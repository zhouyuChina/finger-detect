/* 脚趾图示选择区域 */
.foot-selection-area {
  /* background: linear-gradient(135deg, #e8f5f1 0%, #d4ede5 100%); */
  border-radius: 24rpx;
  /* padding: 40rpx 30rpx; */
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  gap: 30rpx;
  /* border: 2rpx solid #b3ddd0; */
}

.foot-image-preview {
  position: relative;
  width: 100%;
  max-width: 500rpx;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 188, 125, 0.15);
}

.foot-preview-img {
  width: 100%;
  height: 100%;
}

.toe-highlight {
  position: absolute;
  top: 50rpx;
  right: 80rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(0, 188, 125, 0.3);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.3;
  }
}

.selected-part-btn {
  width: 100%;
  background-color: #00BC7D;
  border-radius: 16rpx;
  padding: 25rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected-part-btn .selected-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.instruction-text {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 身体部位选择 - 旧设计（保留以防其他页面使用） */
.body-part-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
}

.body-part-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.body-part-item:active {
  background-color: #e6f3ff;
  border-color: #2B81E8;
}

.part-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.part-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 详细部位选择 */
.detail-part-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
}

.detail-part-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.detail-part-item:active {
  background-color: #e6f3ff;
  border-color: #2B81E8;
}

.detail-part-item .part-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 图片选择界面 */
.detail-part-container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 手部图片容器 */
.hand-image-container {
  position: relative;
  width: 600rpx;
  height: 700rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hand-emoji {
  font-size: 500rpx;
  transform: rotate(0deg);
  /* 优化移动端emoji显示清晰度 */
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji", sans-serif;
  /* 增强对比度和锐度 */
  filter: contrast(1.1) saturate(1.1);
  /* 确保emoji不会模糊 */
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform-style: preserve-3d;
  /* 优化渲染性能 */
  will-change: transform;
}

.hand-emoji.left-hand {
  transform: rotate(0deg) scaleX(-1);
  /* 保持左手翻转时的清晰度 */
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  filter: contrast(1.1) saturate(1.1);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform-style: preserve-3d;
}

/* 手指点击区域 */
.finger-areas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.finger-area {
  position: absolute;
  width: 80rpx;
  height: 100rpx;
  border: 2rpx solid transparent;
  border-radius: 40rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  /* background: red; */
}

.finger-area:active {
  background-color: rgba(43, 129, 232, 0.2);
  border-color: #2B81E8;
}

