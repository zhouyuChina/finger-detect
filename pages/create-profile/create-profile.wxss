  box-shadow: 0 4rpx 20rpx rgba(0, 188, 125, 0.15);
  overflow: hidden;
}

/* 左手时水平翻转 - 不显示过渡动画 */
.hand-image-container.flip-horizontal {
  transform: scaleX(-1);
}

/* 翻转后文字也需要翻转回来 */
.hand-image-container.flip-horizontal .finger-label {
  transform: scaleX(-1);
}

.hand-preview-img {
