/* 自定义弹窗样式 */
.custom-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 10000;
}

.custom-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.custom-popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #ffffff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh; /* 修改为70vh，占屏幕高度的70% */
  min-height: 60vh; /* 添加最小高度，确保至少占60% */
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
} 

/* 覆盖TDesign弹窗样式，使其占更大面积 */
.t-popup--bottom {
  max-height: 70vh !important;
  min-height: 60vh !important;
}

.t-popup--center {
  width: 90vw !important;
  max-width: 90vw !important;
  max-height: 80vh !important;
  min-height: 60vh !important;
}

/* 手部SVG容器 */
.hand-image-container {
  position: relative;
