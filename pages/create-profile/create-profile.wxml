<!--create-profile.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view
      class="step-item {{currentStep >= 1 ? 'active' : ''}}"
    >
      <view class="step-icon">
        <t-icon name="edit" size="40rpx" color="{{currentStep >= 1 ? 'white' : '#999'}}" />
      </view>
      <text class="step-title">档案信息</text>
    </view>
    <view
      class="step-item {{currentStep >= 2 ? 'active' : ''}}"
    >
      <view class="step-icon">
        <t-icon name="camera" size="40rpx" color="{{currentStep >= 2 ? 'white' : '#999'}}" />
      </view>
      <text class="step-title">拍照检测</text>
    </view>
    <view
      class="step-item {{currentStep >= 3 ? 'active' : ''}}"
    >
      <view class="step-icon">
        <t-icon name="check-circle" size="40rpx" color="{{currentStep >= 3 ? 'white' : '#999'}}" />
      </view>
      <text class="step-title">完成</text>
    </view>
  </view>

  <!-- 主要内容区域 -->
  <view class="content-area">
    <!-- 第一步：档案信息 -->
    <view class="step-content" wx:if="{{currentStep === 1}}">
      <view class="section-title">档案信息</view>
      
      <!-- 用户选择区域 -->
      <view class="user-selection-area">
        <!-- 加载状态 -->
        <view class="loading-state" wx:if="{{loading}}">
          <text class="loading-text">加载中...</text>
        </view>
        
        <!-- 错误状态 -->
        <view class="error-state" wx:elif="{{error}}">
          <text class="error-text">{{errorMessage}}</text>
          <button class="retry-btn" bindtap="onRetry">重试</button>
        </view>
        
        <!-- 正常状态 -->
        <view class="selection-placeholder" wx:else bindtap="showUserSelector">
          <text class="placeholder-text">{{selectedUser ? selectedUser.nickname : '请选择用户'}}</text>
        </view>
      </view>
    </view>

    <!-- 未登录用户提示 -->
    <view class="step-content" wx:if="{{currentStep === 1 && !selectedUser && !loading}}">
      <view class="section-title">欢迎使用健康检测</view>
      <view class="welcome-message">
        <text class="welcome-text">您可以直接进行拍照检测，无需完善个人信息</text>
        <text class="welcome-desc">点击下方按钮开始检测</text>
      </view>
    </view>

    <!-- 第二步：选择档案 -->
    <view class="step-content" wx:if="{{currentStep === 2}}">
      <view class="section-title">请选择档案</view>
      
      <!-- 档案列表 -->
      <view class="profile-list" wx:if="{{selectedUserProfiles.length > 0}}">
        <view 
          class="profile-item" 
          wx:for="{{selectedUserProfiles}}" 
          wx:key="id"
          bindtap="selectProfile"
          data-profile="{{item}}"
          data-index="{{index}}"
        >
          <view class="profile-info">
            <view class="profile-name">{{item.name}}</view>
            <view class="profile-meta">
              <text class="meta-item">检测次数: {{item.photoCount}}次</text>
            </view>
          </view>
          <view class="profile-arrow">></view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{selectedUserProfiles.length === 0}}">
        <text class="empty-text">暂无档案，请新增档案</text>
      </view>

      <!-- 新增档案 -->
      <view class="add-profile-section">
        <view class="add-profile-btn" bindtap="addNewProfile">
          <text class="add-icon">➕</text>
          <text class="add-text">新增档案</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button 
      class="btn btn-prev" 
      wx:if="{{currentStep > 1}}"
      bindtap="prevStep"
    >上一步</button>
    <button 
      class="btn btn-next" 
      wx:if="{{currentStep === 1 && selectedUser}}"
      bindtap="nextStep"
    >下一步</button>
    <button 
      class="btn btn-primary" 
      wx:if="{{currentStep === 1 && !selectedUser && !loading}}"
      bindtap="startPhotoDetection"
    >开始拍照检测</button>
  </view>

  <!-- 用户选择弹窗 -->
  <t-popup
    visible="{{showUserSelector}}"
    placement="bottom"
    bind:close="closeUserSelector"
  >
    <view class="user-selector-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeUserSelector">取消</text>
        <text class="selector-title">请选择</text>
        <text class="selector-confirm" bindtap="confirmUserSelection">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option {{selectedUser && selectedUser.id === item.id ? 'selected' : ''}} {{currentSubUser && currentSubUser.id === item.id ? 'default-user' : ''}}" 
          wx:for="{{subUsers}}" 
          wx:key="id"
          bindtap="selectUser"
          data-user="{{item}}"
        >
          <text class="option-text">
            {{item.nickname}}
          </text>
          <text class="option-check" wx:if="{{selectedUser && selectedUser.id === item.id}}">✅</text>
        </view>
        <view class="selector-option add-option" bindtap="addNewUser">
          <text class="option-text">新增用户</text>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <!-- 简单的自定义弹窗 -->
  <view class="custom-popup" wx:if="{{showUserSelector}}">
    <view class="custom-overlay" bindtap="closeUserSelector"></view>
    <view class="custom-popup-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeUserSelector">取消</text>
        <text class="selector-title">请选择</text>
        <text class="selector-confirm" bindtap="confirmUserSelection">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option {{selectedUser && selectedUser.id === item.id ? 'selected' : ''}} {{currentSubUser && currentSubUser.id === item.id ? 'default-user' : ''}}" 
          wx:for="{{subUsers}}" 
          wx:key="id"
          bindtap="selectUser"
          data-user="{{item}}"
        >
          <text class="option-text"> {{item.nickname}} </text>
          <text class="option-check" wx:if="{{selectedUser && selectedUser.id === item.id}}">✅</text>
        </view>
        <view class="selector-option add-option" bindtap="addNewUser">
          <text class="option-text">新增用户</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 用户信息输入弹窗 - 第一步：昵称 -->
  <t-popup
    visible="{{showNicknamePopup}}"
    placement="bottom"
    bind:close="closeNicknamePopup"
  >
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">{{popupTitle}}</text>
        <text class="popup-close" bindtap="closeNicknamePopup">✕</text>
      </view>
      
      <view class="form-content">
        <view class="form-item">
          <text class="form-label">用户昵称</text>
          <input 
            class="form-input" 
            placeholder="请输入用户昵称" 
            value="{{userForm.nickname}}"
            bindinput="onNicknameInput"
            maxlength="20"
          />
          <text class="form-tip {{nicknameError ? 'error-tip' : ''}}" wx:if="{{nicknameError}}">{{nicknameError}}</text>
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <view class="gender-selector">
            <view
              class="gender-option {{userForm.gender === '1' ? 'active' : ''}}"
              bindtap="selectGender"
              data-gender="1"
            >
              <image class="gender-icon" src="/images/male.svg" mode="aspectFit"></image>
              <text class="gender-text">男</text>
            </view>
            <view
              class="gender-option {{userForm.gender === '2' ? 'active' : ''}}"
              bindtap="selectGender"
              data-gender="2"
            >
              <image class="gender-icon" src="/images/female.svg" mode="aspectFit"></image>
              <text class="gender-text">女</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="popup-actions">
        <button class="popup-btn cancel-btn" bindtap="closeNicknamePopup">取消</button>
        <button class="popup-btn confirm-btn" bindtap="nextUserStep">下一步</button>
      </view>
    </view>
  </t-popup>

  <!-- 用户信息输入弹窗 - 第二步：出生年份 -->
  <t-popup
    visible="{{showBirthYearPopup}}"
    placement="bottom"
    bind:close="closeBirthYearPopup"
  >
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">{{popupTitle}}</text>
        <text class="popup-close" bindtap="closeBirthYearPopup">✕</text>
      </view>
      
      <view class="form-content">
        <view class="form-item">
          <text class="form-label">出生年份</text>
          <view class="selection-placeholder" bindtap="showBirthYearSelector">
            <text class="placeholder-text">{{userForm.birthYear || '请选择出生年份'}}</text>
          </view>
        </view>
      </view>
      
      <view class="popup-actions">
        <button class="popup-btn cancel-btn" bindtap="prevUserStep">上一步</button>
        <button class="popup-btn confirm-btn" bindtap="nextUserStep">下一步</button>
      </view>
    </view>
  </t-popup>

  <!-- 用户信息输入弹窗 - 第二步：地址 -->
  <t-popup
    visible="{{showAddressPopup}}"
    placement="bottom"
    bind:close="closeAddressPopup"
  >
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">{{popupTitle}}</text>
        <text class="popup-close" bindtap="closeAddressPopup">✕</text>
      </view>
      
      <view class="form-content">
        <view class="form-item">
          <text class="form-label">省份</text>
          <view class="selection-placeholder" bindtap="showProvinceSelector">
            <text class="placeholder-text">{{userForm.province || '请选择省份'}}</text>

          </view>
        </view>
        <view class="form-item">
          <text class="form-label">城市</text>
          <view class="selection-placeholder" bindtap="showCitySelector">
            <text class="placeholder-text">{{userForm.city || '请选择城市'}}</text>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">区县</text>
          <view class="selection-placeholder" bindtap="showDistrictSelector">
            <text class="placeholder-text">{{userForm.district || '请选择区县'}}</text>
          </view>
        </view>
      </view>
      
      <view class="popup-actions">
        <button class="popup-btn cancel-btn" bindtap="prevUserStep">上一步</button>
        <button class="popup-btn confirm-btn" bindtap="saveUserInfo">{{isCompleteMode ? '保存' : '确定'}}</button>
      </view>
    </view>
  </t-popup>

  <!-- 出生年份选择弹窗 -->
  <t-popup
    visible="{{showBirthYearSelector}}"
    placement="bottom"
    bind:close="closeBirthYearSelector"
  >
    <view class="user-selector-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeBirthYearSelector">取消</text>
        <text class="selector-title">请选择出生年份</text>
        <text class="selector-confirm" bindtap="confirmBirthYear">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option" 
          wx:for="{{birthYearOptions}}" 
          wx:key="*this"
          bindtap="selectBirthYear"
          data-year="{{item}}"
        >
          <text class="option-text">{{item}}年</text>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <!-- 省份选择弹窗 -->
  <t-popup
    visible="{{showProvinceSelector}}"
    placement="bottom"
    bind:close="closeProvinceSelector"
  >
    <view class="user-selector-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeProvinceSelector">取消</text>
        <text class="selector-title">请选择省份</text>
        <text class="selector-confirm" bindtap="confirmProvince">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option" 
          wx:for="{{provinceOptions}}" 
          wx:key="*this"
          bindtap="selectProvince"
          data-province="{{item}}"
        >
          <text class="option-text">{{item}}</text>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <!-- 城市选择弹窗 -->
  <t-popup
    visible="{{showCitySelector}}"
    placement="bottom"
    bind:close="closeCitySelector"
  >
    <view class="user-selector-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeCitySelector">取消</text>
        <text class="selector-title">请选择城市</text>
        <text class="selector-confirm" bindtap="confirmCity">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option" 
          wx:for="{{cityOptions}}" 
          wx:key="*this"
          bindtap="selectCity"
          data-city="{{item}}"
        >
          <text class="option-text">{{item}}</text>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <!-- 区县选择弹窗 -->
  <t-popup
    visible="{{showDistrictSelector}}"
    placement="bottom"
    bind:close="closeDistrictSelector"
  >
    <view class="user-selector-content">
      <view class="selector-header">
        <text class="selector-cancel" bindtap="closeDistrictSelector">取消</text>
        <text class="selector-title">请选择区县</text>
        <text class="selector-confirm" bindtap="confirmDistrict">确定</text>
      </view>
      
      <scroll-view class="selector-options" scroll-y="true">
        <view 
          class="selector-option" 
          wx:for="{{districtOptions}}" 
          wx:key="*this"
          bindtap="selectDistrict"
          data-district="{{item}}"
        >
          <text class="option-text">{{item}}</text>
        </view>
      </scroll-view>
    </view>
  </t-popup>

  <!-- 身体部位选择弹窗 -->
  <t-popup
    visible="{{showBodyPartPopup}}"
    placement="bottom"
    bind:close="closeBodyPartPopup"
    customStyle="width: 100vw; height: 100vh; max-height: 100vh; border-radius: 0; top: 0; left: 0;"
  >
    <view class="popup-content new-design fullscreen">
      <view class="popup-header fullscreen-header">
        <view class="header-left"></view>
        <text class="popup-title">选择部位类型</text>
        <text class="popup-close" bindtap="closeBodyPartPopup">✕</text>
      </view>

      <view class="body-part-section">
        <!-- 手部/脚部选择 -->
        <view class="part-type-selector">
          <view
            class="part-type-btn left-btn {{selectedPartType === 'hand' ? 'active' : ''}}"
            bindtap="selectBodyPart"
            data-part="{{bodyParts[0]}}"
          >
            <text class="part-text">手部</text>
          </view>
          <view
            class="part-type-btn right-btn {{selectedPartType === 'foot' ? 'active' : ''}}"
            bindtap="selectBodyPart"
            data-part="{{bodyParts[2]}}"
          >
            <text class="part-text">脚部</text>
          </view>
        </view>

        <!-- 左右选择 -->
        <view class="section-title">选择左右</view>
        <view class="left-right-selector">
          <view
            class="left-right-btn left-btn {{selectedBodyPart && (selectedBodyPart.value === 'leftFoot' || selectedBodyPart.value === 'leftHand') ? 'active' : ''}}"
            bindtap="selectBodyPart"
            data-part="{{selectedPartType === 'hand' ? bodyParts[0] : bodyParts[2]}}"
          >
            <text class="lr-text">{{selectedPartType === 'hand' ? '左手' : '左脚'}}</text>
          </view>
          <view
            class="left-right-btn right-btn {{selectedBodyPart && (selectedBodyPart.value === 'rightFoot' || selectedBodyPart.value === 'rightHand') ? 'active' : ''}}"
            bindtap="selectBodyPart"
            data-part="{{selectedPartType === 'hand' ? bodyParts[1] : bodyParts[3]}}"
          >
            <text class="lr-text">{{selectedPartType === 'hand' ? '右手' : '右脚'}}</text>
          </view>
        </view>

        <!-- 脚趾/手指图示选择区域 -->
        <view class="section-title">点击进行选择</view>
        <view class="foot-selection-area">
          <!-- 手部图示 -->
          <view class="hand-image-container {{selectedBodyPart && selectedBodyPart.value === 'leftHand' ? 'flip-horizontal' : ''}}" wx:if="{{selectedPartType === 'hand'}}">
            <image class="hand-preview-img" src="/images/rightHand.svg" mode="aspectFit"></image>

            <!-- 可点击的手指区域覆盖层 -->
            <view class="finger-clickable-areas">
              <!-- 大拇指点击区域 -->
              <view
                class="finger-area thumb-area"
                bindtap="selectDetailPart"
                data-part="{{fingerParts[0]}}"
              >
                <text class="finger-label">大拇指</text>
              </view>

              <!-- 食指点击区域 -->
              <view
                class="finger-area index-area"
                bindtap="selectDetailPart"
                data-part="{{fingerParts[1]}}"
              >
                <text class="finger-label">食指</text>
              </view>

              <!-- 中指点击区域 -->
              <view
                class="finger-area middle-area"
                bindtap="selectDetailPart"
                data-part="{{fingerParts[2]}}"
              >
                <text class="finger-label">中指</text>
              </view>

              <!-- 无名指点击区域 -->
              <view
                class="finger-area ring-area"
                bindtap="selectDetailPart"
                data-part="{{fingerParts[3]}}"
              >
                <text class="finger-label">无名指</text>
              </view>

              <!-- 小指点击区域 -->
              <view
                class="finger-area little-area"
                bindtap="selectDetailPart"
                data-part="{{fingerParts[4]}}"
              >
                <text class="finger-label">小指</text>
              </view>
            </view>
          </view>

          <!-- 脚部图示 -->
          <view class="foot-image-container {{selectedBodyPart && selectedBodyPart.value === 'leftFoot' ? 'flip-horizontal' : ''}}" wx:else>
            <image class="foot-preview-img" src="/images/rightFoot.svg" mode="aspectFit"></image>

            <!-- 可点击的脚趾区域覆盖层 -->
            <view class="toe-clickable-areas">
              <!-- 大脚趾点击区域 -->
              <view
                class="toe-area big-toe-area"
                bindtap="selectDetailPart"
                data-part="{{toeParts[0]}}"
              >
                <text class="toe-label">大脚趾</text>
              </view>

              <!-- 第二脚趾点击区域 -->
              <view
                class="toe-area second-toe-area"
                bindtap="selectDetailPart"
                data-part="{{toeParts[1]}}"
              >
                <text class="toe-label">二趾</text>
              </view>

              <!-- 第三脚趾点击区域 -->
              <view
                class="toe-area third-toe-area"
                bindtap="selectDetailPart"
                data-part="{{toeParts[2]}}"
              >
                <text class="toe-label">三趾</text>
              </view>

              <!-- 第四脚趾点击区域 -->
              <view
                class="toe-area fourth-toe-area"
                bindtap="selectDetailPart"
                data-part="{{toeParts[3]}}"
              >
                <text class="toe-label">四趾</text>
              </view>

              <!-- 小脚趾点击区域 -->
              <view
                class="toe-area little-toe-area"
                bindtap="selectDetailPart"
                data-part="{{toeParts[4]}}"
              >
                <text class="toe-label">小趾</text>
              </view>
            </view>
          </view>
        </view>

        <view class="instruction-text">点击图片中的任意{{selectedPartType === 'hand' ? '手指' : '脚趾'}}进行选择</view>
      </view>
    </view>
  </t-popup>

</view> 