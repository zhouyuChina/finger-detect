<!--camera.wxml-->
<view class="container">
  <!-- 相机预览区域 - 只在授权后显示 -->
  <view class="camera-container" wx:if="{{showCamera && cameraAuthorized}}">
    <camera
      device-position="{{devicePosition}}"
      flash="off"
      class="camera"
      binderror="onCameraError"
    >
      <!-- 全屏遮罩层（置灰其他区域） -->
      <view class="camera-overlay">
        <!-- 透明的指甲区域 -->
        <view class="nail-cutout"></view>
      </view>

      <!-- 手指甲引导框 -->
      <view class="finger-guide">
        <view class="guide-items">
          <!-- 第一个引导项 -->
          <view class="guide-item">
            <image class="guide-icon" src="/images/nail-position.svg" mode="aspectFit"></image>
            <text class="guide-text">请把指甲放置于框架内</text>
          </view>

          <!-- 第二个引导项 -->
          <view class="guide-item">
            <image class="guide-icon" src="/images/sunlight.svg" mode="aspectFit"></image>
            <text class="guide-text">确保自然光充足</text>
          </view>

          <!-- 第三个引导项 -->
          <view class="guide-item">
            <image class="guide-icon" src="/images/clean-background.svg" mode="aspectFit" style="width: 66rpx;"></image>
            <text class="guide-text">请确保背景没有杂物</text>
          </view>
        </view>
      </view>
      
      <!-- 顶部操作栏 -->
      <view class="top-bar">
        <view class="back-btn" bindtap="goBack">
          <t-icon name="chevron-left" size="48rpx" color="white" />
        </view>
        <view class="title">拍照检测</view>
        <view class="switch-btn" bindtap="switchCamera">
          <t-icon name="refresh" size="40rpx" color="white" />
        </view>
      </view>
      
      <!-- 底部操作栏 -->
      <view class="bottom-bar">
        <view class="photo-btn" bindtap="takePhoto">
          <view class="photo-btn-inner"></view>
        </view>
      </view>
    </camera>
  </view>

  <!-- 授权引导页面 -->
  <view class="auth-guide" wx:if="{{showCamera && !cameraAuthorized && !isAuthorizing}}">
    <view class="auth-content">
      <image class="auth-icon" src="/images/logo.jpg" mode="aspectFit"></image>
      <view class="auth-title">需要使用相机权限</view>
      <view class="auth-desc">拍照检测需要使用您的相机进行指甲拍摄，点击下方按钮后将弹出授权请求</view>
      <button class="auth-btn" bindtap="handleCameraAuth">开启相机</button>
      <view class="auth-cancel" bindtap="goBack">暂不使用</view>
    </view>
  </view>

  <!-- 授权中加载状态 -->
  <view class="auth-loading" wx:if="{{isAuthorizing}}">
    <view class="loading-content">
      <view class="loading-icon"></view>
      <view class="loading-text">正在启动相机...</view>
    </view>
  </view>

  <!-- 照片预览区域 -->
  <view class="preview-container" wx:if="{{!showCamera}}">
    <image 
      class="preview-image" 
      src="{{photoPath}}" 
      mode="aspectFit"
    ></image>
    
    <!-- 预览操作栏 -->
    <view class="preview-actions">
      <button class="action-btn retake-btn" bindtap="retakePhoto">重新拍照</button>
      <button class="action-btn confirm-btn" bindtap="confirmPhoto">使用照片</button>
    </view>
  </view>

  <!-- 隐藏的canvas用于图片裁剪 -->
  <canvas 
    canvas-id="cropCanvas" 
    class="crop-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  ></canvas>
</view>
