<!--camera.wxml-->
<view class="container">
  <!-- 相机预览区域 -->
  <view class="camera-container" wx:if="{{showCamera}}">
    <camera
      device-position="{{devicePosition}}"
      flash="off"
      class="camera"
      binderror="onCameraError"
    >
      <!-- 全屏遮罩层（置灰其他区域） -->
      <view class="camera-overlay">
        <!-- 透明的指甲区域 -->
        <view class="nail-cutout"></view>
      </view>

      <!-- 手指甲引导框 -->
      <view class="finger-guide">
        <!-- <view class="nail-outline"> -->
          <!-- 指甲轮廓 -->
          <!-- <view class="nail-shape"></view>
        </view> -->
        <text class="guide-text">请把指甲放进框内并尽量铺满框</text>
      </view>
      
      <!-- 顶部操作栏 -->
      <view class="top-bar">
        <view class="back-btn" bindtap="goBack">
          <t-icon name="chevron-left" size="48rpx" color="white" />
        </view>
        <view class="title">拍照检测</view>
        <view class="switch-btn" bindtap="switchCamera">
          <t-icon name="refresh" size="40rpx" color="white" />
        </view>
      </view>
      
      <!-- 底部操作栏 -->
      <view class="bottom-bar">
        <view class="photo-btn" bindtap="takePhoto">
          <view class="photo-btn-inner"></view>
        </view>
      </view>
    </camera>
  </view>

  <!-- 照片预览区域 -->
  <view class="preview-container" wx:if="{{!showCamera}}">
    <image 
      class="preview-image" 
      src="{{photoPath}}" 
      mode="aspectFit"
    ></image>
    
    <!-- 预览操作栏 -->
    <view class="preview-actions">
      <button class="action-btn retake-btn" bindtap="retakePhoto">重新拍照</button>
      <button class="action-btn confirm-btn" bindtap="confirmPhoto">使用照片</button>
    </view>
  </view>

  <!-- 隐藏的canvas用于图片裁剪 -->
  <canvas 
    canvas-id="cropCanvas" 
    class="crop-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  ></canvas>
</view>
