/* camera.wxss */
page {
  background-color: #000;
}

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* 相机容器 */
.camera-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 全屏遮罩层 - 除了指甲区域外其他地方都置灰 */
.camera-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  /* background: rgba(0, 0, 0, 0.75); */
  z-index: 5;
  pointer-events: none;
}

/* 透明的指甲区域（镂空效果） */
.nail-cutout {
  position: absolute;
  top: 46%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 280rpx;
  height: 360rpx;
  /* 使用遮罩混合模式创建镂空效果 */
  background: transparent;
  border-radius: 140rpx 140rpx 0rpx 0rpx / 180rpx 180rpx 80rpx 80rpx;
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.85);
}

/* 手指甲引导框 */
.finger-guide {
  position: absolute;
  top: 16%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  pointer-events: none;
}

.nail-outline {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.nail-shape {
  width: 280rpx;
  height: 360rpx;
  border: 4rpx dashed #00BC7D;
  border-radius: 140rpx 140rpx 80rpx 80rpx / 100rpx 100rpx 80rpx 80rpx;
  position: relative;
  background: rgba(76, 175, 80, 0.05);
  box-shadow:
    0 0 30rpx rgba(76, 175, 80, 0.4),
    inset 0 0 20rpx rgba(76, 175, 80, 0.1);
  animation: pulse-glow 2s ease-in-out infinite;
}

/* 脉冲发光动画 */
@keyframes pulse-glow {
  0%, 100% {
    box-shadow:
      0 0 30rpx rgba(76, 175, 80, 0.4),
      inset 0 0 20rpx rgba(76, 175, 80, 0.1);
  }
  50% {
    box-shadow:
      0 0 50rpx rgba(76, 175, 80, 0.6),
      inset 0 0 30rpx rgba(76, 175, 80, 0.2);
  }
}

.guide-text {
  font-size: 28rpx;
  color: #00BC7D;
  font-weight: 600;
  text-align: center;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 12rpx 24rpx 11rpx;
  border-radius: 25rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid #00BC7D;
  width: 400rpx;
}

/* 顶部操作栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
  z-index: 20;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.switch-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.switch-icon {
  font-size: 36rpx;
  color: #fff;
}

/* 底部操作栏 */
.bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
  z-index: 20;
}

.photo-btn {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  margin-bottom: 300rpx;
}

.photo-btn-inner {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
}

/* 预览容器 */
.preview-container {
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  flex-direction: column;
}

.preview-image {
  flex: 1;
  width: 100%;
  background: #000;
}

.preview-actions {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 40rpx;
  background: rgba(0, 0, 0, 0.8);
}

.action-btn {
  width: 300rpx !important;
  height: 70rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  color: #fff;
}

.retake-btn {
  background: #666;
}

.confirm-btn {
  background: #00BC7D;
}

/* 隐藏的裁剪canvas */
.crop-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  z-index: -1;
}
