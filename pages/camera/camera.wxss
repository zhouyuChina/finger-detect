/* camera.wxss */
page {
  background-color: #000;
}

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* 相机容器 */
.camera-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 全屏遮罩层 - 除了指甲区域外其他地方都置灰 */
.camera-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  /* background: rgba(0, 0, 0, 0.75); */
  z-index: 5;
  pointer-events: none;
}

/* 透明的指甲区域（镂空效果） */
.nail-cutout {
  position: absolute;
  top: 46%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 280rpx;
  height: 360rpx;
  /* 使用遮罩混合模式创建镂空效果 */
  background: transparent;
  border-radius: 140rpx 140rpx 0rpx 0rpx / 180rpx 180rpx 80rpx 80rpx;
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.85);
}

/* 手指甲引导框 */
.finger-guide {
  position: absolute;
  top: 16%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  pointer-events: none;
}

.guide-items {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 40rpx;
  transform: scale(.8);
}

.guide-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.guide-icon {
  width: 80rpx;
  height: 80rpx;
}

.guide-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  white-space: nowrap;
}

/* 顶部操作栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
  z-index: 20;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.switch-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.switch-icon {
  font-size: 36rpx;
  color: #fff;
}

/* 底部操作栏 */
.bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
  z-index: 20;
}

.photo-btn {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  margin-bottom: 300rpx;
}

.photo-btn-inner {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
}

/* 预览容器 */
.preview-container {
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  flex-direction: column;
}

.preview-image {
  flex: 1;
  width: 100%;
  background: #000;
}

.preview-actions {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 40rpx;
  background: rgba(0, 0, 0, 0.8);
}

.action-btn {
  width: 300rpx !important;
  height: 70rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  color: #fff;
}

.retake-btn {
  background: #666;
}

.confirm-btn {
  background: #00BC7D;
}

/* 隐藏的裁剪canvas */
.crop-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  z-index: -1;
}

/* 授权引导页面 */
.auth-guide {
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.auth-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 60rpx;
  border-radius: 80rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  padding: 0 40rpx;
}

.auth-btn {
  width: 500rpx;
  height: 88rpx;
  background: #00BC7D;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 40rpx;
}

.auth-cancel {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 20rpx;
}
