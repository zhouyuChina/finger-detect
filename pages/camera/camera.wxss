/* camera.wxss */
page {
  background-color: #000;
}

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* 相机容器 */
.camera-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 手指引导框 */
.finger-guide {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
  pointer-events: none;
}

.finger-outline {
  width: 300rpx;
  height: 500rpx;
  border: 3rpx dashed #4CAF50;
  border-radius: 100rpx 100rpx 60rpx 60rpx;
  position: relative;
  margin-bottom: 20rpx;
  background: rgba(76, 175, 80, 0.1);
  box-shadow: 0 0 20rpx rgba(76, 175, 80, 0.3);
}

