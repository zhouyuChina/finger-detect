<!--detection-result.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view 
      class="step-item {{item.active ? 'active' : ''}}" 
      wx:for="{{steps}}" 
      wx:key="id"
    >
      <view class="step-icon">{{item.icon}}</view>
      <text class="step-title">{{item.title}}</text>
      <view class="step-line" wx:if="{{index < steps.length - 1}}"></view>
    </view>
  </view>

  <!-- 主要内容区域 -->
  <view class="content-area">
    <!-- 第一部分：照片显示区域 -->
    <view class="image-section">
      <view class="image-container">
        <image 
          class="detection-image" 
          src="{{detectionResult.imagePath || '/images/default-avatar.png'}}" 
          mode="aspectFill"
          bindtap="previewImage"
        />
      </view>
    </view>

    <!-- 第二部分：描述内容 -->
    <view class="description-section">
      <view class="section-title">描述:</view>
      <view class="description-content">
        <text class="description-text">{{detectionResult.description}}</text>
      </view>
    </view>

    <!-- 第三部分：产品使用建议 -->
    <view class="suggestions-section">
      <view class="section-title">产品的使用建议:</view>
      <view class="suggestions-content">
        <text class="suggestions-text">{{detectionResult.suggestions}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn btn-save" bindtap="saveToProfile">保存到档案</button>
    <button class="btn btn-home" bindtap="backToHome">返回首页</button>
  </view>
</view> 