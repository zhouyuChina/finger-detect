<!--detection-result.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view 
      class="step-item {{item.active ? 'active' : ''}}" 
      wx:for="{{steps}}" 
      wx:key="id"
    >
      <view class="step-icon">{{item.icon}}</view>
      <text class="step-title">{{item.title}}</text>
      <view class="step-line" wx:if="{{index < steps.length - 1}}"></view>
    </view>
  </view>

  <!-- 主要内容区域 -->
  <view class="content-area">
    <view class="result-section">
      <!-- 成功图标 -->
      <view class="success-icon">✅</view>
      
      <!-- 检测结果 -->
      <view class="result-title">检测完成</view>
      <view class="result-status">{{detectionResult.status}}</view>
      <view class="result-details">{{detectionResult.details}}</view>

      <!-- 建议列表 -->
      <view class="recommendations">
        <view class="recommendations-title">健康建议</view>
        <view class="recommendation-list">
          <view 
            class="recommendation-item" 
            wx:for="{{detectionResult.recommendations}}" 
            wx:key="*this"
          >
            <text class="recommendation-dot">•</text>
            <text class="recommendation-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn btn-report" bindtap="viewDetailedReport">查看详细报告</button>
    <button class="btn btn-save" bindtap="saveToProfile">保存到档案</button>
    <button class="btn btn-home" bindtap="backToHome">返回首页</button>
  </view>
</view> 