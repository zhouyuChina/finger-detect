/* detection-result.wxss */
page {
  background-color: #ffffff;
}

.container {
  padding: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  width: calc(100vw - 60rpx);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.step-item.active .step-icon {
  background-color: #00BC7D;
  border-color: #00BC7D;
  color: #ffffff;
}

.step-title {
  font-size: 24rpx;
  color: #666;
}

.step-item.active .step-title {
  color: #00BC7D;
  font-weight: 600;
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 40rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  animation: spin 2s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.report-wrapper {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.report-title {
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2f36;
  letter-spacing: 2rpx;
}

.report-card {
  position: relative;
  background-color: #ffffff;
  border: 2rpx solid #1f5662;
  border-radius: 16rpx;
  padding: 40rpx 36rpx;
  box-shadow: 14rpx 14rpx 0 rgba(182, 220, 226, 0.6);
}

.card-corner {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  border: 4rpx solid #8fd3df;
  background-color: #ffffff;
  transform: rotate(45deg);
}

.corner-tl {
  top: -14rpx;
  left: 40rpx;
}

.corner-tr {
  top: -14rpx;
  right: 40rpx;
}

.card-header {
  margin-bottom: 28rpx;
}

.card-header-bottom {
  margin-bottom: 0rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2f36;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #1f2f36;
  white-space: nowrap;
  margin-right: 10rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.result-field {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.field-label {
  font-size: 28rpx;
  color: #1f2f36;
  margin-right: 20rpx;
}

.result-badge {
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

.badge-normal {
  background-color: #1fba72;
}

.badge-abnormal {
  background-color: #ff6b6b;
}

.badge-unknown {
  background-color: #ffcc4d;
  color: #433c1c;
}

.result-image-container {
  height: 420rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #9fd6df;
  background-color: #f4fbfc;
  padding: 24rpx;
}

.image-container {
  /* width: 100%; */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.detection-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.advice-content {
  margin-bottom: 20rpx;
}

.advice-paragraph {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
}

.advice-item {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.advice-item:last-child {
  margin-bottom: 0;
}

.advice-note {
  color: #1f5662;
  margin-top: 12rpx;
}

.advice-card .advice-content:last-child {
  margin-bottom: 0;
}

/* 操作按钮 */
.action-buttons {
  padding: 0rpx 30rpx 100rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
}

.btn-save {
  background-color: #00BC7D;
  color: #ffffff;
}

.btn-home {
  background-color: #f5f5f5;
  color: #666;
}

.nav-btn {
  width: 100%;
  display: block;
}