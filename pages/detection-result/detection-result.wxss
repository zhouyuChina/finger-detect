/* detection-result.wxss */
page {
  background-color: #ffffff;
}

.container {
  padding: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.step-item.active .step-icon {
  background-color: #4CAF50;
  border-color: #4CAF50;
  color: #ffffff;
}

.step-title {
  font-size: 24rpx;
  color: #666;
}

.step-item.active .step-title {
  color: #4CAF50;
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 30rpx;
  right: -50%;
  width: 100%;
  height: 2rpx;
  background-color: #e0e0e0;
  z-index: -1;
}

.step-item.active .step-line {
  background-color: #4CAF50;
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-section {
  width: 100%;
  text-align: center;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.result-status {
  font-size: 48rpx;
  color: #4CAF50;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.result-details {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

/* 建议列表 */
.recommendations {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.recommendations-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  text-align: left;
}

.recommendation-list {
  text-align: left;
}

.recommendation-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.recommendation-item:last-child {
  margin-bottom: 0;
}

.recommendation-dot {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 10rpx;
  margin-top: 4rpx;
}

.recommendation-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  flex: 1;
}

/* 操作按钮 */
.action-buttons {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
}

.btn-report {
  background-color: #2196F3;
  color: #ffffff;
}

.btn-save {
  background-color: #4CAF50;
  color: #ffffff;
}

.btn-home {
  background-color: #f5f5f5;
  color: #666;
} 