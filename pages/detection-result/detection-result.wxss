/* detection-result.wxss */
page {
  background-color: #ffffff;
}

.container {
  padding: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  width: calc(100vw - 60rpx);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.step-item.active .step-icon {
  background-color: #00BC7D;
  border-color: #00BC7D;
  color: #ffffff;
}

.step-title {
  font-size: 24rpx;
  color: #666;
}

.step-item.active .step-title {
  color: #00BC7D;
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 30rpx;
  right: -50%;
  width: 100%;
  height: 2rpx;
  background-color: #e0e0e0;
  z-index: -1;
}

.step-item.active .step-line {
  background-color: #00BC7D;
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  animation: spin 2s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 第一部分：照片显示区域 */
.image-section {
  width: 100%;
  margin-bottom: 20rpx;
}

.image-container {
  width: 100%;
  height: 600rpx;
  background-color: #f5f5f5;
  border: 2rpx solid #2196F3;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.detection-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* 第二部分：检测结果状态 */
.result-status-section {
  width: 100%;
}

.status-content {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
}

.status-item {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.status-item.warning {
  background-color: #fff3cd;
  color: #856404;
  border: 1rpx solid #ffeaa7;
}

.status-item.success {
  background-color: #d4edda;
  color: #155724;
  border: 1rpx solid #c3e6cb;
}

.status-item.info {
  background-color: #d1ecf1;
  color: #0c5460;
  border: 1rpx solid #bee5eb;
}

.status-text {
  font-size: 28rpx;
  font-weight: 600;
}

/* 第三部分：描述内容 */
.description-section {
  width: 100%;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  /* margin-bottom: 20rpx; */
}

.description-content {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 10rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

/* 第三部分：产品使用建议 */
.suggestions-section {
  width: 100%;
}

.suggestions-content {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 10rpx;
}

.suggestions-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

/* 操作按钮 */
.action-buttons {
  padding: 0rpx 30rpx 100rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
}

.btn-save {
  background-color: #00BC7D;
  color: #ffffff;
}

.btn-home {
  background-color: #f5f5f5;
  color: #666;
} 