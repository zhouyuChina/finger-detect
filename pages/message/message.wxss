/* message.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  display: flex;
  flex-direction: column;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  width: 90vw;
}

.message-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  padding: 24rpx;
  position: relative;
}

/* 消息项样式 */
.message-item.unread {
  background-color: #f8f9ff;
}

.message-item.top {
  border-left: 4rpx solid #ff6b35;
}

.message-item.important {
  border-left: 4rpx solid #ff4757;
}

.message-item.top.important {
  border-left: 4rpx solid #ff6b35;
}

/* 消息封面图片 */
.message-image {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 120rpx;
  height: 80rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.message-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 未读红点 */
.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 8rpx;
  border: 2rpx solid white;
}

/* 消息图标（无封面图片时显示） */
.message-icon {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-bg {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.icon-bg.tech {
  background-color: #2196F3;
}

.icon-bg.health {
  background-color: #4CAF50;
}

.icon-bg.news {
  background-color: #ffa726;
}

.icon-text {
  font-size: 24rpx;
}

/* 消息内容 */
.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.title-container {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 16rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.top-icon {
  margin-left: 8rpx;
  flex-shrink: 0;
}

.top-icon-text {
  font-size: 24rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.message-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.message-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

/* 标签样式 */
.top-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #ff6b35;
  color: white;
}

.important-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #ff4757;
  color: white;
}

.category-tag {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #f0f0f0;
  color: #666;
}

.read-count {
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  background-color: #e3f2fd;
  color: #1976d2;
}

/* 作者信息 */
.message-author {
  margin-top: 4rpx;
}

.author-text {
  font-size: 22rpx;
  color: #999;
}



/* 自定义底部导航栏 */
.custom-bottom-nav {
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  padding: 10rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 10rpx 0;
}

.nav-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
  color: #666;
}

.nav-text {
  font-size: 20rpx;
  color: #666;
}

.lightning-badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  font-size: 16rpx;
  color: #007aff;
}

/* 激活状态 */
.nav-item.active .nav-icon {
  color: #ff6b35;
}

.nav-item.active .nav-text {
  color: #ff6b35;
  font-weight: 500;
}

.nav-item.active {
  border-top: 3rpx solid #ff6b35;
}
