<!--message.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 消息列表 -->
  <view class="message-list" wx:if="{{!loading && messageList.length > 0}}">
    <view class="message-item" wx:for="{{messageList}}" wx:key="id" bindtap="onMessageClick" data-id="{{item.id}}">
      <view class="message-title">{{item.title}}</view>
      <view class="message-image">
        <image src="{{item.image}}" mode="aspectFill" />
      </view>
      <view class="message-metrics">
        <view class="metric-item">
          <text class="metric-icon">阅读量：</text>
          <text class="metric-text">{{item.views}}</text>
        </view>
        <view class="metric-item">
          <text class="metric-icon">发布时间：</text>
          <text class="metric-text">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && messageList.length === 0}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">暂无消息</view>
    <view class="empty-desc">下拉刷新获取最新消息</view>
  </view>
</view> 