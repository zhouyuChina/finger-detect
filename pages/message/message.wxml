<!--message.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 消息列表 -->
  <view class="message-list" wx:if="{{!loading && messageList.length > 0}}">
    <view class="message-item {{item.isRead ? 'read' : 'unread'}} {{item.isTop ? 'top' : ''}} {{item.isImportant ? 'important' : ''}}" 
          wx:for="{{messageList}}" wx:key="id" bindtap="onMessageClick" data-id="{{item.id}}">
      
      <!-- 消息封面图片 -->
      <view class="message-image" wx:if="{{item.image}}">
        <image src="{{item.image}}" mode="aspectFill" />
        <!-- 未读红点 -->
        <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
      </view>
      
      <!-- 消息图标（无封面图片时显示） -->
      <view class="message-icon" wx:if="{{!item.image}}">
        <view class="icon-bg {{item.category === '技术资讯' ? 'tech' : item.category === '健康提醒' ? 'health' : 'news'}}">
          <text class="icon-text">{{item.category === '技术资讯' ? '技' : item.category === '健康提醒' ? '健' : '资'}}</text>
        </view>
        <!-- 未读红点 -->
        <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
      </view>
      
      <view class="message-content">
        <view class="message-header">
          <view class="title-container">
            <text class="message-title">{{item.title}}</text>
            <!-- 置顶图标 -->
            <view class="top-icon" wx:if="{{item.isTop}}">
              <text class="top-icon-text">📌</text>
            </view>
          </view>
          <text class="message-time">{{item.time}}</text>
        </view>
        
        <!-- 消息摘要 -->
        <text class="message-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
        
        <!-- 消息标签 -->
        <view class="message-tags">
          <!-- 置顶标签 -->
          <text class="top-tag" wx:if="{{item.isTop}}">置顶</text>
          <!-- 重要标签 -->
          <text class="important-tag" wx:if="{{item.isImportant}}">重要</text>
          <!-- 分类标签 -->
          <text class="category-tag">{{item.category}}</text>
          <!-- 阅读数 -->
          <text class="read-count" wx:if="{{item.views > 0}}">{{item.views}}阅读</text>
        </view>
        
        <!-- 作者信息 -->
        <view class="message-author" wx:if="{{item.author}}">
          <text class="author-text">作者：{{item.author}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && messageList.length === 0}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">暂无消息</view>
    <view class="empty-desc">下拉刷新获取最新消息</view>
  </view>
</view> 