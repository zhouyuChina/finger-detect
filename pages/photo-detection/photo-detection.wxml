<!--photo-detection.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view 
      class="step-item {{currentStep >= 1 ? 'active' : ''}}" 
    >
      <view class="step-icon">✏️</view>
      <text class="step-title">档案信息</text>
    </view>
    <view 
      class="step-item {{currentStep >= 2 ? 'active' : ''}}" 
    >
      <view class="step-icon">📷</view>
      <text class="step-title">拍照操作</text>
    </view>
    <view 
      class="step-item {{currentStep >= 3 ? 'active' : ''}}" 
    >
      <view class="step-icon">✅</view>
      <text class="step-title">完成</text>
    </view>
  </view>

  <!-- 主要内容区域 -->
  <view class="content-area">
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-icon">⏳</view>
      <text class="loading-text">检查档案状态中...</text>
    </view>
    
    <!-- 错误状态 -->
    <view class="error-state" wx:elif="{{error}}">
      <view class="error-icon">❌</view>
      <text class="error-text">档案信息获取失败</text>
      <button class="retry-btn" bindtap="onRetry">重试</button>
    </view>
    
    <!-- 正常状态 -->
    <view class="photo-section" wx:else>
      <view class="photo-title">
        <text>请拍照进行检测或记录</text>
      </view>
      
      <!-- 档案信息显示 -->
      <view class="profile-info" wx:if="{{profile}}">
        <text class="profile-name">{{profile.name}}</text>
        <text class="profile-desc">{{profile.bodyPart}} - {{profile.detailPart}}</text>
      </view>
      
      <!-- 无档案信息提示 -->
      <view class="profile-info no-profile" wx:if="{{!profile}}">
        <text class="profile-name">{{defaultProfile.name}}</text>
        <text class="profile-desc">{{defaultProfile.bodyPart}} - {{defaultProfile.detailPart}}</text>
        <text class="profile-tip">临时档案，拍照后可进行授权</text>
      </view>
      
      <!-- 拍照区域 -->
      <view class="photo-area">
        <view class="photo-placeholder" wx:if="{{!photoTaken}}">
          <view class="camera-icon">📷</view>
          <text class="placeholder-text">点击拍照</text>
        </view>
        
        <!-- 图片预览容器 -->
        <view class="photo-preview-container" wx:if="{{photoTaken}}">
          <image 
            class="photo-preview" 
            src="{{photoPath}}" 
            mode="aspectFit"
          ></image>
          
          <!-- 检测扫描动画 -->
          <view class="scan-loading" wx:if="{{isDetecting}}">
            <view class="scan-overlay">
              <view class="scan-line"></view>
              <text class="scan-text">AI检测分析中...</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 操作按钮区域 -->
      <view class="photo-actions">
        <!-- 拍照按钮 -->
        <button 
          class="btn btn-photo" 
          wx:if="{{!photoTaken}}"
          bindtap="takePhoto"
        >拍照</button>
        
        <!-- 临时上传按钮 -->
        <!-- <button 
          class="btn btn-upload" 
          wx:if="{{!photoTaken}}"
          bindtap="uploadPhoto"
        >上传图片</button> -->
        
        <!-- 拍照后的操作按钮 -->
        <view class="btn-group" wx:if="{{photoTaken}}">
          <!-- <button class="btn btn-retake" bindtap="retakePhoto">重新拍照</button> -->
          <!-- <button class="btn btn-retake" bindtap="retakePhoto">重新拍照/上传</button> -->
          <!-- 两个选择按钮：任何时候都显示 -->
          <button 
            class="btn btn-detect {{isDetecting ? 'btn-disabled' : ''}}" 
            bindtap="startDetection"
            disabled="{{isDetecting}}"
          >
            {{isDetecting ? '检测中...' : '开始检测'}}
          </button>
          <button 
            class="btn btn-save {{isDetecting ? 'btn-disabled' : ''}}" 
            bindtap="savePhotoOnly"
            disabled="{{isDetecting}}"
          >
            仅保存图片
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户信息获取弹窗 -->
  <view class="user-profile-modal" wx:if="{{showUserProfileModal}}">
    <view class="modal-overlay" bindtap="closeUserProfileModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">获取用户信息</text>
        <text class="modal-close" bindtap="closeUserProfileModal">✕</text>
      </view>
      <view class="modal-body">
        <text class="modal-desc">为了提供更好的服务，需要获取您的微信头像和昵称</text>
        <button class="btn btn-primary" bindtap="getUserProfile">确认授权</button>
        <button class="btn btn-cancel" bindtap="closeUserProfileModal">取消</button>
      </view>
    </view>
  </view>
</view> 