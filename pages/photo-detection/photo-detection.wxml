<!--photo-detection.wxml-->
<view class="container">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view 
      class="step-item {{currentStep >= 1 ? 'active' : ''}}" 
    >
      <view class="step-icon">✏️</view>
      <text class="step-title">档案信息</text>
    </view>
    <view 
      class="step-item {{currentStep >= 2 ? 'active' : ''}}" 
    >
      <view class="step-icon">📷</view>
      <text class="step-title">{{hasReports ? '拍照记录' : '拍照检测'}}</text>
    </view>
    <view 
      class="step-item {{currentStep >= 3 ? 'active' : ''}}" 
    >
      <view class="step-icon">✅</view>
      <text class="step-title">完成</text>
    </view>
  </view>

  <!-- 主要内容区域 -->
  <view class="content-area">
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-icon">⏳</view>
      <text class="loading-text">检查档案状态中...</text>
    </view>
    
    <!-- 错误状态 -->
    <view class="error-state" wx:elif="{{error}}">
      <view class="error-icon">❌</view>
      <text class="error-text">档案信息获取失败</text>
      <button class="retry-btn" bindtap="onRetry">重试</button>
    </view>
    
    <!-- 正常状态 -->
    <view class="photo-section" wx:else>
      <view class="photo-title">
        {{hasReports ? '请拍照记录治疗进展' : '请开始拍照检测'}}
      </view>
      
      <!-- 档案信息显示 -->
      <view class="profile-info" wx:if="{{profile}}">
        <text class="profile-name">{{profile.name}}</text>
        <text class="profile-desc">{{profile.bodyPart}} - {{profile.detailPart}}</text>
      </view>
      
      <!-- 拍照区域 -->
      <view class="photo-area">
        <view class="photo-placeholder" wx:if="{{!photoTaken}}">
          <view class="camera-icon">📷</view>
          <text class="placeholder-text">点击拍照</text>
        </view>
        
        <image 
          class="photo-preview" 
          wx:if="{{photoTaken}}" 
          src="{{photoPath}}" 
          mode="aspectFit"
        ></image>
      </view>

      <!-- 拍照按钮 -->
      <view class="photo-actions">
        <button 
          class="btn btn-photo" 
          wx:if="{{!photoTaken}}"
          bindtap="takePhoto"
        >拍照</button>
        
        <view class="btn-group" wx:if="{{photoTaken}}">
          <button class="btn btn-retake" bindtap="retakePhoto">重新拍照</button>
          <!-- 暂时隐藏保存记录按钮，后端会自动处理灰指甲的数据库存储 -->
          <button class="btn btn-detect" bindtap="startDetection" wx:if="{{!hasReports}}">
            开始检测
          </button>
        </view>
      </view>
    </view>
  </view>
</view> 