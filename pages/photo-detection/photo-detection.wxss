/* photo-detection.wxss */
page {
  background-color: #ffffff;
}

.container {
  padding: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  width: calc(100vw - 60rpx);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid #e0e0e0;
}

.step-item.active .step-icon {
  background-color: #4CAF50;
  border-color: #4CAF50;
  color: #ffffff;
}

.step-title {
  font-size: 24rpx;
  color: #666;
}

.step-item.active .step-title {
  color: #4CAF50;
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 30rpx;
  right: -50%;
  width: 100%;
  height: 2rpx;
  background-color: #e0e0e0;
  z-index: -1;
}

.step-item.active .step-line {
  background-color: #4CAF50;
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: start;
  margin-top: 20rpx;
  width: calc(100vw - 60rpx);
}

.photo-section {
  width: 100%;
  text-align: center;
}

.photo-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 60rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  animation: spin 2s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.retry-btn {
  padding: 20rpx 40rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

/* 档案信息 */
.profile-info {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.profile-name {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.profile-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 无档案信息样式 */
.profile-info.no-profile {
  background-color: #fff3cd;
  border: 1rpx solid #ffeaa7;
}

.profile-info.no-profile .profile-name {
  color: #856404;
}

.profile-info.no-profile .profile-desc {
  color: #856404;
}

.profile-tip {
  display: block;
  font-size: 24rpx;
  color: #856404;
  margin-top: 8rpx;
  font-style: italic;
}

/* 拍照区域 */
.photo-area {
  width: 100%;
  margin-bottom: 60rpx;
}

/* 授权提示区域 */
.auth-placeholder {
  width: 100%;
  height: 500rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
  text-align: center;
  padding: 40rpx;
}

.auth-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.auth-title {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.auth-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 40rpx;
  max-width: 400rpx;
}

.photo-placeholder {
  width: 100%;
  height: 500rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.camera-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

/* 图片预览容器 */
.photo-preview-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-preview {
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

/* 扫描加载动画 */
.scan-loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  z-index: 10;
}

.scan-overlay {
  position: relative;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 0%, #4CAF50 50%, transparent 100%);
  box-shadow: 0 0 20rpx #4CAF50;
  animation: scan-move 2s ease-in-out infinite;
}

.scan-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  z-index: 20;
  margin-top: 40rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes scan-move {
  0% {
    top: 0;
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  50% {
    top: calc(100% - 4rpx);
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    top: 0;
    opacity: 0;
  }
}

/* 拍照按钮 */
.photo-actions {
  width: 100%;
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
  margin-bottom: 20rpx;
}

.btn-photo {
  background-color: #4CAF50;
  color: #ffffff;
}

.btn-auth {
  background-color: #4CAF50;
  color: #ffffff;
  font-weight: 500;
}

.btn-upload {
  background-color: #FF9800;
  color: #ffffff;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.btn-retake {
  flex: 1;
  background-color: #f5f5f5;
  color: #666;
  min-width: 140rpx;
}

.btn-detect {
  flex: 1;
  background-color: #4CAF50;
  color: #ffffff;
  min-width: 140rpx;
}

.btn-save {
  flex: 1;
  background-color: #2196F3;
  color: #ffffff;
  min-width: 140rpx;
}

/* 按钮禁用状态 */
.btn-disabled {
  background-color: #cccccc !important;
  color: #666666 !important;
  opacity: 0.6;
}

/* 用户信息获取弹窗 */
.user-profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 10000;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f8f8f8;
}

.modal-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 40rpx 30rpx;
  text-align: center;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  border: none;
  margin-bottom: 20rpx;
  width: 100%;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  border: none;
  width: 100%;
} 