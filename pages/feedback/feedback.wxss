/* feedback.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0;
  width: 100vw;
}

/* Tab标签页样式 */
.feedback-tabs {
  background-color: #fff;
}

.feedback-section, .message-section  {
  width: 100vw;
}

/* 留言板块样式 */
.message-section {
  padding: 20rpx;
}

/* 留言表单 */
.message-form {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.form-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.form-content {
  padding: 30rpx;
}

.input-group {
  margin-bottom: 30rpx;
  position: relative;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.message-title-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.message-title-input:focus {
  border-color: #0052d9;
  background-color: #fff;
}

.message-content-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.message-content-textarea:focus {
  border-color: #0052d9;
  background-color: #fff;
}

.char-count {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.form-actions {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}

/* 留言列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-header {
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.message-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.message-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.12);
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.message-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

.message-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.message-image {
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.message-image image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}



.message-metrics {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.metric-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.metric-icon {
  font-size: 24rpx;
}

.metric-text {
  font-size: 24rpx;
  color: #999;
}

/* 反馈板块样式 */
.feedback-section {
  padding: 20rpx;
}



.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feedback-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.feedback-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.12);
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.feedback-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.feedback-time {
  font-size: 24rpx;
  color: #999;
}

.feedback-title {
  margin-bottom: 15rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.feedback-content {
  margin-bottom: 20rpx;
}

.feedback-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.feedback-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.feedback-status {
  display: flex;
  justify-content: flex-end;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #999;
}

/* 反馈详情弹窗样式 */
.detail-popup {
  width: 90vw; /* 修改为90vw，占屏幕宽度的90% */
  max-width: 90vw; /* 确保最大宽度不超过90vw */
  max-height: 85vh; /* 修改为85vh，占屏幕高度的85% */
  min-height: 60vh; /* 添加最小高度，确保至少占60% */
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.popup-close:active {
  background-color: #e0e0e0;
}

.popup-title-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.feedback-type-tag {
  flex-shrink: 0;
}

.popup-content {
  padding: 40rpx;
  max-height: 65vh; /* 修改为65vh，给内容更多空间 */
  overflow-y: auto;
  flex: 1; /* 让内容区域占据剩余空间 */
}

.feedback-info {
  margin-bottom: 30rpx;
}

.feedback-time {
  font-size: 24rpx;
  color: #999;
}

.feedback-body {
  margin-bottom: 30rpx;
}

.feedback-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.feedback-reply {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  border-left: 4rpx solid #0052d9;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.reply-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0052d9;
}

.reply-time {
  font-size: 22rpx;
  color: #999;
}

.reply-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* 操作按钮 */
.popup-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-actions .t-button {
  flex: 1;
}

/* 消息详情弹窗样式 */
.detail-popup {
  width: 600rpx;
  max-height: 90vh;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.popup-title-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.message-type-tag {
  flex-shrink: 0;
}

.popup-content {
  padding: 40rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.message-info {
  margin-bottom: 30rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.message-body {
  margin-bottom: 30rpx;
}

.message-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.message-image {
  margin-bottom: 30rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.message-image image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
} 