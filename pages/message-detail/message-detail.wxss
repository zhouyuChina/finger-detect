/* message-detail.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  justify-content: start;
}

/* 文章头部 */
.article-header {
  background-color: #fff;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
  width: 90vw;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.publish-time, .read-count {
  display: flex;
  align-items: center;
}

/* 文章内容 */
.article-content {
  background-color: #fff;
  width: 90vw;
  box-sizing: border-box;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 30rpx;
  text-align: justify;
}

.article-image {
  margin: 30rpx 0;
  border-radius: 8rpx;
  overflow: hidden;
}

.article-image image {
  width: 100%;
  height: auto;
  display: block;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.tag {
  background-color: #f0f8ff;
  color: #007aff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 相关推荐 */
.related-articles {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  width: calc(100% - 40rpx);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  width: 100%;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.related-item {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  border-left: 4rpx solid #007aff;
  width: 100%;
  box-sizing: border-box;
}

.related-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  line-height: 1.4;
  width: 100%;
  word-wrap: break-word;
  word-break: break-all;
}

.related-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  width: 100%;
}

.related-time, .related-views {
  display: flex;
  align-items: center;
}

