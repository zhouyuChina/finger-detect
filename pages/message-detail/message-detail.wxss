/* message-detail.wxss */
.container {
  background-color: #f2fef9;
  min-height: 100vh;
  padding: 0;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 30rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.error-btn {
  padding: 20rpx 40rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 文章内容 */
.article-content {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 文章标题 */
.article-header {
  padding: 40rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
}

/* 文章摘要 */
.article-summary {
  padding: 20rpx 30rpx;
  background-color: #f8f9fa;
  border-bottom: 10rpx solid #eee;
}

.summary-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  font-style: italic;
}

/* 文章封面图片 */
.article-cover {
  width: 100%;
  max-height: 400rpx;
  overflow: hidden;
}

.article-cover image {
  width: 100%;
  height: auto;
}

/* 文章标签 */
.article-tags {
  padding: 20rpx 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tag {
  padding: 8rpx 16rpx;
  background-color: #e6f7ff;
  color: #1890ff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 文章正文 */
.article-body {
  padding: 30rpx;
  line-height: 1.8;
  text-align: center;
}

.article-body rich-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* 文章信息 */
.article-info {
  padding: 20rpx 30rpx;
  background-color: #f8f9fa;
  border-top: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

