/* system-messages.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  justify-content: start;
}

/* 页面头部 */
.page-header {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  width: calc(100vw - 60rpx);
  margin-top: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.unread-badge {
  display: flex;
  align-items: center;
}

/* 消息列表 */
.messages-list {
  margin-top: 20rpx;
}

/* 消息图标 */
.message-icon {
  position: relative;
  margin-right: 20rpx;
}

.icon-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.icon-container.unread {
  background-color: rgba(227, 77, 89, 0.1);
}

.unread-dot {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #e34d59;
  border: 3rpx solid #fff;
}

/* 消息标题 */
.message-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 8rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.message-type-tag {
  flex-shrink: 0;
}

/* 消息预览 */
.message-preview {
  margin-bottom: 8rpx;
}

.preview-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 消息元信息 */
.message-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  width: 138rpx;
}

.time-text {
  font-size: 24rpx;
  color: #999;
}

.read-count {
  display: flex;
  justify-content: flex-end;
}

.count-text {
  font-size: 22rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
}

/* 详情弹窗 */
.detail-popup {
  width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-title-section {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.popup-close:active {
  background-color: #e0e0e0;
}

/* 弹窗内容 */
.popup-content {
  padding: 40rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.message-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.message-time {
  font-size: 28rpx;
  color: #999;
}

.read-count {
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.message-body {
  margin-bottom: 30rpx;
}

.message-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  text-align: justify;
}

.message-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.message-actions .t-button {
  flex: 1;
}

/* 弹窗操作按钮 */
.popup-actions {
  display: flex;
  gap: 20rpx;
  padding: 40rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-actions .t-button {
  flex: 1;
}

/* 加载更多 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
}

.no-more-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态样式 */
.t-empty {
  margin-top: 100rpx;
}