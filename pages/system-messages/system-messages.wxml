<!--system-messages.wxml-->
<view class="container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">系统消息</text>
    <view class="header-actions">
      <view wx:if="{{unreadCount > 0}}" class="unread-badge">
        <t-badge count="{{unreadCount}}" theme="danger" />
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <view class="messages-list">
    <t-cell-group>
      <t-cell 
        wx:for="{{messages}}" 
        wx:key="id"
        bindtap="onMessageClick"
        data-id="{{item.id}}"
        hover
      >
        <view slot="left-icon" class="message-icon">
          <view class="icon-container">
            <t-icon 
              name="{{getMessageIcon(item.type)}}" 
              size="48rpx" 
              color="#666"
            />
          </view>
        </view>
        
        <view slot="title" class="message-title">
          <text class="title-text">{{item.title}}</text>
          <view class="message-type-tag">
            <t-tag theme="light" size="small">{{getMessageTypeText(item.type)}}</t-tag>
          </view>
        </view>
        
        <view slot="description" class="message-preview">
          <text class="preview-text">{{item.content}}</text>
        </view>
        
        <view slot="note" class="message-meta">
          <text class="time-text">{{formatTime(item.publishedAt)}}</text>
          <view class="read-count">
            <text class="count-text">{{item.readCount}}/{{item.totalCount}}</text>
          </view>
        </view>
      </t-cell>
    </t-cell-group>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <t-loading theme="circular" size="40rpx" text="加载中..." />
    </view>

    <!-- 没有更多数据 -->
    <view wx:if="{{!hasMore && messages.length > 0}}" class="no-more">
      <text class="no-more-text">没有更多消息了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <t-empty 
    wx:if="{{messages.length === 0 && !loading}}"
    description="暂无系统消息"
    icon="notification"
  >
    <t-button 
      slot="action" 
      theme="primary" 
      size="medium"
      bindtap="goToHome"
    >
      返回首页
    </t-button>
  </t-empty>

  <!-- 消息详情弹窗 -->
  <t-popup 
    visible="{{showDetailPopup}}" 
    placement="center" 
    bind:visible-change="onDetailPopupChange"
    close-on-overlay-click="{{true}}"
  >
    <view class="detail-popup">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <view class="popup-title-section">
          <text class="popup-title">{{currentMessage.title}}</text>
          <view class="message-type-tag">
            <t-tag theme="light" size="small">{{getMessageTypeText(currentMessage.type)}}</t-tag>
          </view>
        </view>
        <text class="popup-close" bindtap="closeDetailPopup">×</text>
      </view>

      <!-- 消息内容 -->
      <view class="popup-content">
        <view class="message-info">
          <text class="message-time">{{formatTime(currentMessage.publishedAt)}}</text>
        </view>
        
        <view class="message-body">
          <text class="message-content">{{currentMessage.content}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="popup-actions">
        <t-button 
          theme="light" 
          size="small"
          bindtap="closeDetailPopup"
        >
          关闭
        </t-button>
      </view>
    </view>
  </t-popup>
</view> 