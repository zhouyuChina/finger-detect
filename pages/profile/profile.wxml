<!--profile.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <t-loading 
    theme="circular" 
    size="40rpx" 
    loading="{{loading}}"
    class="loading-container"
  />
  
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info">
      <view class="user-avatar">
        <t-icon name="user" size="48rpx" color="white" />
      </view>
      <view class="user-details">
        <text class="user-name">{{userInfo.name || '微信用户'}}</text>
        <text class="user-type">普通用户</text>
      </view>
    </view>
    <t-button
      theme=""
      bindtap="onFeedback"
      size="small"
      class="feedback-btn"
      style="background-color: #009966; width: 160rpx; color: #fff;"
    >
      管理反馈
    </t-button>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-number">{{stats.totalRecords}}</text>
        <text class="stats-label">用户数目</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{stats.totalReports}}</text>
        <text class="stats-label">建档记录</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{stats.familyMembers}}</text>
        <text class="stats-label">检测记录</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{stats.unreadMessages}}</text>
        <text class="stats-label">未使用数</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="menu-list">
      <view class="menu-item" bindtap="onMyProfile">
        <view class="menu-icon user-icon">
          <t-icon name="user" size="44rpx" color="#009966" />
        </view>
        <view class="menu-content">
          <text class="menu-title">用户中心</text>
          <text class="menu-desc">管理我的用户</text>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>

      <view class="menu-item" bindtap="onMyCoupons">
        <view class="menu-icon coupon-icon">
          <t-icon name="discount" size="44rpx" color="#009966" />
        </view>
        <view class="menu-content">
          <text class="menu-title">我的优惠券</text>
          <text class="menu-desc">查看详细的优惠券信息</text>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>

      <view class="menu-item" bindtap="onSystemMessages">
        <view class="menu-icon message-icon">
          <t-icon name="notification" size="44rpx" color="#009966" />
        </view>
        <view class="menu-content">
          <text class="menu-title">系统消息</text>
          <text class="menu-desc">查看系统消息</text>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>

      <view class="menu-item" bindtap="onAboutUs">
        <view class="menu-icon about-icon">
          <t-icon name="help-circle" size="44rpx" color="#009966" />
        </view>
        <view class="menu-content">
          <text class="menu-title">关于我们</text>
          <text class="menu-desc">了解更多产品信息</text>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="#ccc" />
      </view>
    </view>
  </view>
  
</view> 