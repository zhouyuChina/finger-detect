<!--profile.wxml-->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-info">
      <t-avatar 
        image="{{userInfo.avatar}}" 
        size="large"
        shape="round"
      />
      <view class="user-details">
        <text class="user-name">{{userInfo.name}}</text>
        <text class="user-phone">{{userInfo.phone}}</text>
      </view>
    </view>
    <t-button 
      theme="primary"
      bindtap="onEditProfile"
      size="extra-small"
    >
      留言反馈
    </t-button>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stats-item" bindtap="onViewRecords">
        <text class="stats-number">{{stats.totalRecords}}</text>
        <text class="stats-label">拍照记录</text>
      </view>
      <view class="stats-item" bindtap="onViewReports">
        <text class="stats-number">{{stats.totalReports}}</text>
        <text class="stats-label">报告记录</text>
      </view>
      <view class="stats-item" bindtap="onViewFamily">
        <text class="stats-number">{{stats.familyMembers}}</text>
        <text class="stats-label">建档记录</text>
      </view>
      <view class="stats-item" bindtap="onSystemMessages">
        <text class="stats-number">{{stats.unreadMessages}}</text>
        <text class="stats-label">未读消息</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <t-cell-group theme="card">
      <t-cell 
        title="我的档案" 
        description="管理个人健康档案"
        bindtap="onMyProfile"
      >
        <text slot="note" class="arrow-icon">›</text>
      </t-cell>
      <t-cell 
        title="检测记录" 
        description="查看历史检测记录"
        bindtap="onMyRecords"
      >
        <text slot="note" class="arrow-icon">›</text>
      </t-cell>
      <t-cell 
        title="我的优惠券" 
        description="查看详细的优惠券信息"
        bindtap="onMyCoupons"
      >
        <text slot="note" class="arrow-icon">›</text>
      </t-cell>
      <t-cell 
        title="系统消息" 
        description="查看系统消息"
        bindtap="onSystemMessages"
      >
        <text slot="note" class="arrow-icon">›</text>
      </t-cell>
      <t-cell 
        title="关于我们" 
        description="了解更多产品信息"
        bindtap="onAboutUs"
      >
        <text slot="note" class="arrow-icon">›</text>
      </t-cell>
    </t-cell-group>
  </view>

  <!-- 分享有礼 -->
  <view class="share-section">
    <t-cell 
      title="分享有礼" 
      description="邀请好友获得专属优惠"
      hover
      bindtap="onShare"
    >
      <view slot="note" class="note-container">
        <t-tag theme="warning" size="small">有奖励</t-tag>
      </view>
    </t-cell>
  </view>

  <!-- 留言反馈弹窗 -->
  <t-popup 
    visible="{{showFeedbackPopup}}" 
    placement="center" 
    bind:visible-change="onFeedbackPopupChange"
    close-on-overlay-click="{{false}}"
  >
    <view class="feedback-popup">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <text class="popup-title">留言反馈</text>
        <text class="popup-close" bindtap="closeFeedbackPopup">×</text>
      </view>

      <!-- 反馈表单 -->
      <view class="feedback-form">
        <!-- 反馈类型 -->
        <view class="feedback-type">
          <text class="section-title">反馈类型</text>
          <view class="type-options">
            <view 
              class="type-option {{feedbackType === 'bug' ? 'active' : ''}}"
              bindtap="selectType"
              data-type="bug"
            >
              <text class="type-text">问题反馈</text>
            </view>
            <view 
              class="type-option {{feedbackType === 'suggestion' ? 'active' : ''}}"
              bindtap="selectType"
              data-type="suggestion"
            >
              <text class="type-text">功能建议</text>
            </view>
            <view 
              class="type-option {{feedbackType === 'other' ? 'active' : ''}}"
              bindtap="selectType"
              data-type="other"
            >
              <text class="type-text">其他</text>
            </view>
          </view>
        </view>

        <!-- 反馈内容 -->
        <view class="feedback-content">
          <text class="section-title">反馈内容</text>
          <textarea 
            class="feedback-textarea"
            placeholder="请详细描述您的问题或建议..."
            value="{{feedbackContent}}"
            bindinput="onContentInput"
            maxlength="500"
          />
          <text class="char-count">{{feedbackContent.length}}/500</text>
        </view>

        <!-- 联系方式 -->
        <view class="contact-info">
          <text class="section-title">联系方式（选填）</text>
          <input 
            class="contact-input"
            placeholder="请输入您的手机号或邮箱"
            value="{{contactInfo}}"
            bindinput="onContactInput"
          />
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="popup-actions">
        <t-button 
          theme="light" 
          size="samll"
          bindtap="closeFeedbackPopup"
        >
          取消
        </t-button>
        <t-button 
          theme="primary" 
          size="samll"
          bindtap="submitFeedback"
          disabled="{{!feedbackContent.trim()}}"
        >
          提交反馈
        </t-button>
      </view>
    </view>
  </t-popup>
</view> 