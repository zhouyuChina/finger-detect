/* profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  position: relative;
}

/* 加载状态样式 */
.loading-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 40rpx;
}

/* 用户信息区域 */
.user-section {
  background-color: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10rpx 0;
  width: 82vw;
}

/* 留言反馈按钮样式 */
.user-section .t-button {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
  width: 128rpx;
  height: 56rpx;
  margin-left: auto;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  width: 60%;
}

.user-details {
  margin-left: 30rpx;
  flex: 1;
  width: 100%;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

/* 统计信息区域 */
.stats-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 10rpx;
  width: 84vw;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.stats-item:active {
  background-color: #e9ecef;
  transform: scale(0.95);
}

.stats-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  display: block;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  display: block;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 0rpx;
  width: 100vw;
}

/* 分享区域 */
.share-section {
  margin-bottom: 20rpx;
}

.t-cell {
  padding: 20rpx !important;
  margin-bottom: 10rpx;
}

/* 箭头图标样式 */
.arrow-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 分享有礼的note容器 */
.note-container {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 留言反馈弹窗样式 */
.feedback-popup {
  width: 600rpx;
  max-height: 90vh;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  padding: 10rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.popup-close:active {
  background-color: #e0e0e0;
}

.feedback-form {
  padding: 40rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

/* 反馈类型选择 */
.feedback-type {
  margin-bottom: 40rpx;
}

.type-options {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0rpx 20rpx 10rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
}

.type-option.active {
  border-color: #2B81E8;
  background-color: #2B81E8;
}

.type-option:active {
  transform: scale(0.95);
}

.type-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.type-option.active .type-text {
  color: #fff;
}

/* 反馈内容 */
.feedback-content {
  margin-bottom: 40rpx;
  position: relative;
}

.feedback-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.feedback-textarea:focus {
  border-color: #2B81E8;
  background-color: #fff;
}

.char-count {
  position: absolute;
  bottom: 10rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 联系方式 */
.contact-info {
  margin-bottom: 20rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.contact-input:focus {
  border-color: #2B81E8;
  background-color: #fff;
}

/* 弹窗操作按钮 */
.popup-actions {
  display: flex;
  gap: 20rpx;
  padding: 40rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.popup-actions .t-button {
  flex: 1;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .popup-header {
    padding: 30rpx 20rpx;
  }
  
  .feedback-form {
    padding: 30rpx 20rpx;
  }
  
  .popup-actions {
    padding: 30rpx 20rpx;
    flex-direction: column;
  }
  
  .type-options {
    flex-direction: column;
    gap: 15rpx;
  }
}