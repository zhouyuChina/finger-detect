/* 用户信息区域 */
.user-section {
  background-color: #fff;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10rpx 0 0 0;
  width: 92vw;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .4);
  border-radius: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

/* 用户头像 */
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #009966, #009966);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-details {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-type {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 管理反馈按钮包装器 */
.feedback-btn-wrapper {
  position: relative;
  display: inline-block;
}

/* 管理反馈按钮样式 */
.feedback-btn {
  font-size: 26rpx !important;
  background-color: #009966;
  /* padding: 12rpx 12rpx !important; */
  /* height: auto !important; */
  border-radius: 32rpx !important;
  width: 120rpx;
}

/* 留言反馈红点 */
.feedback-badge {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 统计信息区域 */
.stats-section {
  background-color: transparent;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  width: 100vw;
  box-sizing: border-box;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stats-item {
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.stats-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #009966;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.stats-label {
  font-size: 22rpx;
  color: #666;
  display: block;
  line-height: 1.2;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 20rpx;
  width: 100vw;
  box-sizing: border-box;
  padding: 0 30rpx;
}

.menu-list {
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  margin-left: 6rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .4);
  margin-bottom: 30rpx;
  width: calc(100vw - 130rpx);
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #fff;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f8f8f8;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #E8F5E9;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.3;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.3;
}

/* 分享有礼区域 */
.share-section {
  padding: 0 30rpx 40rpx;
  width: 100vw;
  box-sizing: border-box;
}

.share-card {
  background: linear-gradient(135deg, #00BC7D, #00BC7D);
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}

.share-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.share-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  line-height: 1.3;
}

.share-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.share-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.share-btn {
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid white;
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: white;
  line-height: 1;
  height: auto;
}

.share-btn::after {
  border: none;
}

.share-btn-text {
  color: white;
  font-size: 26rpx;
  font-weight: 500;
}

.share-icon {
  flex-shrink: 0;
}
