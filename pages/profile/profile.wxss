/* profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
}

/* 用户信息区域 */
.user-section {
  background-color: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10rpx 0;
  width: 82vw;
}

/* 留言反馈按钮样式 */
.user-section .t-button {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
  width: 128rpx;
  height: 56rpx;
  margin-left: auto;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  width: 60%;
}

.user-details {
  margin-left: 30rpx;
  flex: 1;
  width: 100%;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.user-tags {
  display: flex;
  gap: 12rpx;
}

/* 统计信息区域 */
.stats-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 10rpx;
  width: 84vw;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.stats-item:active {
  background-color: #e9ecef;
  transform: scale(0.95);
}

.stats-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  display: block;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  display: block;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 0rpx;
  width: 100vw;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 20rpx;
}

/* 分享区域 */
.share-section {
  margin-bottom: 20rpx;
}

/* 退出登录区域 */
.logout-section {
  padding: 0 40rpx 40rpx;
} 

.t-cell {
  padding: 20rpx !important;
  margin-bottom: 10rpx;
}

/* 箭头图标样式 */
.arrow-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 分享有礼的note容器 */
.note-container {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.t-class-note {
  align-items: center;
}