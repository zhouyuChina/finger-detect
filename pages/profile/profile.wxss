/* profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  position: relative;
}

/* 加载状态样式 */
.loading-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 40rpx;
}

/* 用户信息区域 */
.user-section {
  background-color: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10rpx 0;
  width: 82vw;
}

/* 留言反馈按钮样式 */
.user-section .t-button {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
  width: 128rpx;
  height: 56rpx;
  margin-left: auto;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  width: 60%;
}

.user-details {
  margin-left: 30rpx;
  flex: 1;
  width: 100%;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

/* 统计信息区域 */
.stats-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 10rpx;
  width: 84vw;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background-color: #f8f9fa;
}

.stats-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  display: block;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  display: block;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 0rpx;
  width: 100vw;
}

/* 分享区域 */
.share-section {
  margin-bottom: 20rpx;
}

.t-cell {
  padding: 20rpx !important;
  margin-bottom: 10rpx;
}

/* 箭头图标样式 */
.arrow-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 分享有礼的note容器 */
.note-container {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 带红点的描述容器 */
.description-with-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 自定义红点样式 */
.red-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #e34d59;
  border-radius: 50%;
  margin-left: 8rpx;
}

/* 带红点的note容器 */
.note-with-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

