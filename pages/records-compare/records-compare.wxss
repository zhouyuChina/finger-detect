/* records.wxss */
.container {
  background-color: #f2fef9;
  min-height: 100vh;
  padding: 0;
  display: block;
}

/* 搜索区域 */
.search-section {
  background-color: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.search-wrapper {
  position: relative;
}

/* 下拉列表样式 */
.dropdown-list {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  max-height: 500rpx;
  overflow-y: auto;
  z-index: 1000;
  margin-top: 8rpx;
}

.dropdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background-color: #f5f5f5;
}

.dropdown-item-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dropdown-item-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 筛选区域 */
.filter-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 10;
}

.tab-content {
  padding: 20rpx;
  min-height: 200rpx;
}

.record-stats {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.stats-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.stats-desc {
  font-size: 24rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  background-color: transparent;
  border-radius: 0rpx;
  overflow: visible;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 给每个 t-cell 添加阴影和圆角 */
.record-list .t-cell {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 0 !important;
  overflow: hidden;
}

.record-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

/* 单元格描述容器 */
.cell-description {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 检测部位样式 */
.body-part {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 更新时间样式 */
.update-time {
  font-size: 24rpx;
  color: #999;
}

/* 检测次数样式 */
.record-count {
  font-size: 24rpx;
  color: #666;
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 用户列表样式 */
.user-list {
  background-color: transparent;
  border-radius: 0rpx;
  overflow: visible;
}

.user-list-header {
  padding: 20rpx;
  border-bottom: none;
  background-color: transparent;
  margin-bottom: 20rpx;
}

.user-list-title {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-list-desc {
  font-size: 24rpx;
  color: #999;
}

.user-list-content {
  background-color: transparent;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 给用户列表中的每个 t-cell 添加阴影和圆角 */
.user-list-content .t-cell {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 0 !important;
  overflow: hidden;
  /* border: 1px solid #333; */
}

/* 用户信息样式 */
.user-id {
  font-size: 24rpx;
  color: #666;
}

.user-archive-count {
  font-size: 24rpx;
  color: #999;
}

/* 返回区域样式 */
.back-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.current-user {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}



 