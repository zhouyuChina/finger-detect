/* about.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
}

.content {
  padding: 0;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #f5f5f5;
}

/* Logo区域 */
.logo-section {
  background-color: #fff;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.logo-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.logo-text {
  font-size: 60rpx;
}

.logo-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin: 0 auto 30rpx;
  display: block;
}

.platform-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.version-text {
  font-size: 28rpx;
  color: #666;
  display: block;
}

/* 介绍区域 */
.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 20rpx 0;
}

.feature-list {
  padding: 20rpx 0;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.feature-item text {
  font-size: 28rpx;
  color: #333;
}

.feature-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

/* 联系信息区域 */
.contact-section {
  margin-bottom: 20rpx;
}

/* 版本信息区域 */
.version-section {
  margin-bottom: 40rpx;
}

/* 操作按钮区域 */
.action-section {
  padding: 0 40rpx 40rpx;
} 

.t-cell {
  padding: 20rpx 40rpx !important;
}