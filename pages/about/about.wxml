<!--about.wxml-->
<view class="container">
  <!-- 主要内容 -->
  <view class="content">
    <!-- Logo区域 -->
    <view class="logo-section">
      <view class="logo-placeholder">
        <text class="logo-text">🏥</text>
      </view>
      <text class="platform-name">{{platformName}}</text>
      <text class="version-text">版本 {{version}}</text>
    </view>

    <!-- 介绍文案 -->
    <view class="description-section">
      <t-cell-group>
        <t-cell title="平台介绍" hover>
          <view slot="description" class="description-text">
            我们致力于为用户提供专业、便捷的健康检测服务。通过先进的AI技术，为用户提供准确、快速的健康分析报告。
          </view>
        </t-cell>
        
        <t-cell title="核心功能" hover>
          <view slot="description" class="feature-list">
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>AI智能检测分析</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>专业健康报告</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>多用户档案管理</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>历史记录追踪</text>
            </view>
          </view>
        </t-cell>
      </t-cell-group>
    </view>

    <!-- 联系信息 -->
    <view class="contact-section">
      <t-cell-group>
        <t-cell 
          title="客服电话" 
          description="400-123-4567"
          hover
          bindtap="onCallService"
          right-icon="chevron-right"
        />
        <t-cell 
          title="官方网站" 
          description="www.healthdetect.com"
          hover
          bindtap="onVisitWebsite"
          right-icon="chevron-right"
        />
        <t-cell 
          title="意见反馈" 
          description="点击提交您的建议"
          hover
          bindtap="onFeedback"
          right-icon="chevron-right"
        />
      </t-cell-group>
    </view>

    <!-- 版本信息 -->
    <view class="version-section">
      <t-cell-group>
        <t-cell title="当前版本" description="{{version}}" />
        <t-cell title="更新日期" description="{{updateDate}}" />
      </t-cell-group>
    </view>

  </view>
</view> 