<!--about.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>

  <!-- 主要内容 -->
  <view class="content" wx:else>
    <!-- Logo区域 -->
    <view class="logo-section">
      <image class="logo-image" src="/images/logo.jpg" mode="aspectFit" />
      <text class="platform-name">月牙康AI甲部检测</text>
      <text class="version-text">版本 {{aboutInfo.version}}</text>
    </view>

    <!-- 介绍文案 -->
    <view class="description-section">
      <t-cell-group>
        <t-cell title="平台介绍" hover>
          <view slot="description" class="description-text">
            旨在构建⼀个⾯向个⼈的以⼩程序服务平台,通过降低检测⻔槛、辅助护理跟踪、提升⽤户体验与信任度。⽤户通过微信⼩程序⾃主上传⼿指甲图像,即可获得AI检测结果作为参考。系统将提供从智能识别、标准建档、图像⽐对到护理跟踪的全流程⽀持,提升检测效率与⾃我健康管理能⼒。
          </view>
        </t-cell>
        
        <!-- <t-cell title="核心功能" hover>
          <view slot="description" class="feature-list">
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>AI智能检测分析</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>专业健康报告</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>多用户档案管理</text>
            </view>
            <view class="feature-item">
              <text class="feature-icon">✅</text>
              <text>历史记录追踪</text>
            </view>
          </view>
        </t-cell> -->

      </t-cell-group>
    </view>

    <!-- 联系信息 -->
    <view class="contact-section">
      <t-cell-group>
        <t-cell 
          wx:if="{{aboutInfo.phone}}"
          title="客服电话" 
          description="{{aboutInfo.phone}}"
          hover
          bindtap="onCallService"
          right-icon="chevron-right"
        />
        <t-cell 
          wx:if="{{aboutInfo.website}}"
          title="官方网站" 
          description="{{aboutInfo.website}}"
          hover
          bindtap="onVisitWebsite"
          right-icon="chevron-right"
        />
        <t-cell 
          wx:if="{{aboutInfo.email}}"
          title="联系邮箱" 
          description="{{aboutInfo.email}}"
          hover
          bindtap="onCopyEmail"
          right-icon="chevron-right"
        />
        <t-cell 
          wx:if="{{aboutInfo.wechat}}"
          title="微信公众号" 
          description="{{aboutInfo.wechat}}"
          hover
          bindtap="onCopyWechat"
          right-icon="chevron-right"
        />
        <t-cell 
          wx:if="{{aboutInfo.address}}"
          title="公司地址" 
          description="{{aboutInfo.address}}"
          hover
        />
        <!-- <t-cell 
          title="意见反馈" 
          description="点击提交您的建议"
          hover
          bindtap="onFeedback"
          right-icon="chevron-right"
        /> -->
      </t-cell-group>
    </view>

    <!-- 版本信息 -->
    <view class="version-section">
      <t-cell-group>
        <t-cell title="当前版本" description="{{aboutInfo.version}}" />
        <!-- <t-cell wx:if="{{aboutInfo.copyright}}" title="版权信息" description="{{aboutInfo.copyright}}" /> -->
      </t-cell-group>
    </view>

  </view>
</view> 