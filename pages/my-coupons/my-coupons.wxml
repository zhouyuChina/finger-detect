<!--my-coupons.wxml-->
<view class="container">
  <!-- 顶部标签页 -->
  <view class="tabs-section">
    <view class="tab-item {{activeTab === 'unused' ? 'active' : ''}}" bindtap="switchTab" data-tab="unused">
      <text class="tab-text">未使用</text>
    </view>
    <view class="tab-item {{activeTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">
      <text class="tab-text">已使用</text>
    </view>
    <view class="tab-item {{activeTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">
      <text class="tab-text">已过期</text>
    </view>
  </view>



  <!-- 优惠券列表 -->
  <view class="coupons-list">
    <view 
      class="coupon-item" 
      wx:for="{{filteredCoupons}}" 
      wx:key="id"
      bindtap="onCouponClick"
      data-id="{{item.id}}"
    >
      <!-- 优惠券信息 -->
      <view class="coupon-info">
        <view class="coupon-header">
          <view class="coupon-name">{{item.coupon.name}}</view>
          <view class="coupon-status {{item.status}}">{{item.status === 'unused' ? '未使用' : item.status === 'used' ? '已使用' : '已过期'}}</view>
        </view>
        
        <view class="coupon-value">{{item.coupon.displayValue}}</view>
        <view class="coupon-condition">{{item.coupon.displayCondition}}</view>
        <view class="coupon-description">{{item.coupon.displayDescription}}</view>
        
        <view class="coupon-footer">
          <view class="coupon-expire">有效期至：{{item.coupon.endTime}}</view>
          <view class="coupon-remaining" wx:if="{{item.status === 'unused'}}">
            {{item.coupon.remainingTimeText}}
          </view>
        </view>
      </view>

      <!-- 状态显示 -->
      <view class="coupon-action">
        <view class="status-overlay">
          <text class="status-text">{{item.status === 'unused' ? '未使用' : item.status === 'used' ? '已使用' : '已过期'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="加载中..."></t-loading>
  </view>

  <!-- 没有更多数据 -->
  <view class="no-more" wx:if="{{!hasMore && filteredCoupons.length > 0}}">
    <text>没有更多数据了</text>
  </view>

  <!-- 空状态 -->
  <t-empty 
    wx:if="{{filteredCoupons.length === 0}}"
    description="暂无优惠券"
    icon="coupon"
  >
    <t-button 
      slot="action" 
      theme="primary" 
      size="medium"
      bindtap="goToHome"
    >
      去首页看看
    </t-button>
  </t-empty>
</view> 