/* my-coupons.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  justify-content: start;
}

/* 顶部标签页 */
.tabs-section {
  background-color: #fff;
  display: flex;
  padding: 0 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100vw;
}

.tab-item {
  flex: 1;
  padding: 30rpx 0;
  text-align: center;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #e34d59;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #e34d59;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #666;
}

.tab-item.active .tab-text {
  color: #e34d59;
  font-weight: 600;
}



/* 优惠券列表 */
.coupons-list {
  padding: 0 40rpx;
}

.coupon-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.coupon-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  border-radius: 4rpx;
}

/* 优惠券信息 */
.coupon-info {
  flex: 1;
  min-width: 0;
}

.coupon-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.coupon-status {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.coupon-status.unused {
  background-color: #e8f5e8;
  color: #52c41a;
}

.coupon-status.used {
  background-color: #f0f0f0;
  color: #999;
}

.coupon-status.expired {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.coupon-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #e34d59;
  margin-bottom: 10rpx;
  line-height: 1;
}

.coupon-condition {
  font-size: 28rpx;
  color: #e34d59;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.coupon-description {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  margin-bottom: 15rpx;
}

.coupon-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.coupon-expire {
  font-size: 24rpx;
  color: #666;
}

.coupon-remaining {
  font-size: 24rpx;
  color: #e34d59;
  font-weight: 500;
}

/* 状态显示 */
.coupon-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.status-overlay {
  width: 120rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e0e0e0;
}

.status-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态样式 */
.t-empty {
  margin-top: 100rpx;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .coupon-item {
    padding: 20rpx;
    gap: 20rpx;
  }
  
  .coupon-image {
    width: 100rpx;
    height: 100rpx;
  }
  
  .coupon-value {
    font-size: 40rpx;
  }
  
  .claim-btn {
    width: 60rpx;
    height: 120rpx;
  }
  
  .btn-text {
    font-size: 18rpx;
  }
} 