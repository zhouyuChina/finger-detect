<!--auth.wxml-->
<view class="container">
  <!-- 授权蒙版 -->
  <view class="auth-overlay" wx:if="{{showAuth}}">
    <view class="auth-content">
      <!-- Logo区域 -->
      <view class="logo-section">
        <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
        <text class="app-name">手指专业检测</text>
        <text class="app-desc">专业 AI 分析平台</text>
      </view>

      <!-- 授权说明 -->
      <view class="auth-section">
        <view class="auth-title">
          <text class="title-text">欢迎使用</text>
        </view>

        <view class="auth-desc">
          <text class="desc-text">点击开始使用，后续将完善您的个人信息</text>
        </view>
      </view>

      <!-- 授权按钮 -->
      <view class="auth-buttons">
        <button
          class="auth-btn primary"
          bindtap="getUserProfile"
          loading="{{loading}}"
          disabled="{{loading}}"
        >
          {{loading ? '注册中...' : '开始使用'}}
        </button>
      </view>

      <!-- 隐私说明 -->
      <view class="privacy-section">
        <text class="privacy-text">
          授权即表示您同意我们的
          <text class="privacy-link">《用户协议》</text>
          和
          <text class="privacy-link">《隐私政策》</text>
        </text>
      </view>
    </view>
  </view>

  <!-- 成功页面 -->
  <view class="success-page" wx:if="{{!showAuth}}">
    <view class="success-content">
      <view class="success-icon">✅</view>
      <text class="success-title">注册成功</text>
      <text class="success-desc">正在跳转到完善信息页面...</text>
    </view>
  </view>
</view> 