<!--auth.wxml-->
<view class="container">
  <!-- 授权蒙版 -->
  <view class="auth-overlay" wx:if="{{showAuth}}">
    <view class="auth-content">
      <!-- Logo区域 -->
      <view class="logo-section">
        <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
        <text class="app-name">健康检测</text>
        <text class="app-desc">专业AI健康分析平台</text>
      </view>

      <!-- 授权说明 -->
      <view class="auth-section">
        <view class="auth-title">
          <text class="title-text">需要获取您的信息</text>
        </view>
        
        <view class="auth-desc">
          <text class="desc-text">为了更好地为您提供个性化服务，我们需要获取您的基本信息</text>
        </view>

        <view class="auth-benefits">
          <view class="benefit-item">
            <text class="benefit-icon">👤</text>
            <text class="benefit-text">个性化推荐</text>
          </view>
          <view class="benefit-item">
            <text class="benefit-icon">📊</text>
            <text class="benefit-text">健康数据分析</text>
          </view>
          <view class="benefit-item">
            <text class="benefit-icon">🔒</text>
            <text class="benefit-text">数据安全保护</text>
          </view>
        </view>
      </view>

      <!-- 授权按钮 -->
      <view class="auth-buttons">
        <button 
          class="auth-btn primary"
          bindtap="getUserProfile"
          loading="{{loading}}"
          disabled="{{loading}}"
        >
          {{loading ? '授权中...' : '立即授权'}}
        </button>
        
        <button 
          class="auth-btn secondary"
          bindtap="skipAuth"
          disabled="{{loading}}"
        >
          暂不授权
        </button>
      </view>

      <!-- 隐私说明 -->
      <view class="privacy-section">
        <text class="privacy-text">
          授权即表示您同意我们的
          <text class="privacy-link">《用户协议》</text>
          和
          <text class="privacy-link">《隐私政策》</text>
        </text>
      </view>
    </view>
  </view>

  <!-- 成功页面 -->
  <view class="success-page" wx:if="{{!showAuth}}">
    <view class="success-content">
      <view class="success-icon">✅</view>
      <text class="success-title">授权成功</text>
      <text class="success-desc">正在为您跳转到首页...</text>
    </view>
  </view>
</view> 