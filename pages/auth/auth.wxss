/* auth.wxss */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景页面 */
.background-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #009966 0%, #00BC7D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.background-content {
  text-align: center;
  color: #fff;
}

.background-logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  border-radius: 32rpx;
}

.background-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.background-subtitle {
  display: block;
  font-size: 32rpx;
  opacity: 0.9;
}

/* 授权弹窗内容 */
.auth-popup-content {
  background: #fff;
  padding: 48rpx 40rpx 60rpx;
  border-radius: 32rpx 32rpx 0 0;
  text-align: center;
}

/* 弹窗头部 */
.auth-popup-header {
  margin-bottom: 40rpx;
}

.auth-icon-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.auth-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.auth-popup-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.auth-popup-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

/* 授权说明 */
.auth-description {
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 授权按钮 */
.auth-actions {
  margin-bottom: 32rpx;
  padding: 0 20rpx;
}

/* 隐私说明 */
.auth-privacy {
  padding: 0 20rpx;
}

.privacy-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.privacy-link {
  color: #009966;
  text-decoration: underline;
}

/* 成功弹窗 */
.success-popup {
  background: #fff;
  padding: 60rpx 80rpx;
  border-radius: 24rpx;
  text-align: center;
  min-width: 500rpx;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.success-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
} 