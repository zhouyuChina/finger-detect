/* auth.wxss */
.container {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

/* 授权蒙版 */
.auth-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.auth-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

/* Logo区域 */
.logo-section {
  margin-bottom: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.app-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

/* 授权说明 */
.auth-section {
  margin-bottom: 60rpx;
}

.auth-title {
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.auth-desc {
  margin-bottom: 40rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 授权好处 */
.auth-benefits {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.benefit-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.benefit-text {
  font-size: 24rpx;
  color: #666;
}

/* 授权按钮 */
.auth-buttons {
  margin-bottom: 40rpx;
}

.auth-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
}

.auth-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.auth-btn.primary:active {
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
}

.auth-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.auth-btn.secondary:active {
  background: #e8e8e8;
}

.auth-btn[disabled] {
  opacity: 0.6;
}

/* 隐私说明 */
.privacy-section {
  padding: 20rpx 0;
}

.privacy-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.privacy-link {
  color: #667eea;
  text-decoration: underline;
}

/* 成功页面 */
.success-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  text-align: center;
  color: #fff;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.success-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
} 