<!--records.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-section">
    <t-search 
      placeholder="搜索检测记录" 
      bind:submit="onSearch"
      bind:change="onSearchChange"
      value="{{searchValue}}"
    />
  </view>

  <!-- 记录列表 -->
  <view class="records-section">
    <view class="records-header">
      <text class="header-title">检测记录</text>
      <text class="header-count">共 {{filteredRecords.length}} 条记录</text>
    </view>
    
    <view class="records-list" wx:if="{{filteredRecords.length > 0}}">
      <t-cell 
        wx:for="{{filteredRecords}}" 
        wx:key="id"
        bindtap="onRecordClick"
        data-id="{{item.id}}"
        hover
      >
        <view slot="left-icon" class="record-icon">
          <view class="icon-container">
            <t-icon name="file" size="48rpx" color="#2B81E8" />
          </view>
        </view>
        
        <view slot="title" class="record-title">
          <text class="title-text">检测报告 #{{item.id}}</text>
        </view>
        
        <view slot="description" class="record-preview">
          <text class="preview-text">{{item.description}}</text>
        </view>
        
        <view slot="note" class="record-meta">
          <text class="time-text">{{item.createTime}}</text>
          <view class="record-actions">
            <t-button 
              size="small" 
              theme="danger" 
              variant="outline"
              bindtap="deleteRecord"
              data-id="{{item.id}}"
              catchtap="deleteRecord"
            >
              删除
            </t-button>
          </view>
        </view>
      </t-cell>
    </view>
    
    <!-- 空状态 -->
    <t-empty 
      wx:if="{{filteredRecords.length === 0}}"
      description="暂无检测记录"
      icon="file"
    >
      <t-button 
        slot="action" 
        theme="primary" 
        size="medium"
        bindtap="goToDetection"
      >
        开始检测
      </t-button>
    </t-empty>
  </view>

  <!-- 记录详情弹窗 -->
  <t-popup 
    visible="{{showDetailPopup}}" 
    placement="center" 
    bind:visible-change="onDetailPopupChange"
    close-on-overlay-click="{{true}}"
  >
    <view class="detail-popup">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <text class="popup-title">检测报告详情</text>
        <text class="popup-close" bindtap="closeDetailPopup">×</text>
      </view>

      <!-- 报告内容 -->
      <view class="popup-content">
        <!-- 照片显示区域 -->
        <view class="image-section">
          <view class="image-container">
            <image 
              class="detection-image" 
              src="{{currentRecord.imagePath || '/images/banner1.png'}}" 
              mode="aspectFill"
              bindtap="previewImage"
            />
          </view>
        </view>

        <!-- 描述内容 -->
        <view class="description-section">
          <view class="section-title">描述:</view>
          <view class="description-content">
            <text class="description-text">{{currentRecord.description}}</text>
          </view>
        </view>

        <!-- 使用建议 -->
        <view class="suggestions-section">
          <view class="section-title">产品的使用建议:</view>
          <view class="suggestions-content">
            <text class="suggestions-text">{{currentRecord.suggestions}}</text>
          </view>
        </view>

        <!-- 报告信息 -->
        <view class="report-info">
          <view class="info-item">
            <text class="info-label">检测时间:</text>
            <text class="info-value">{{currentRecord.createTime}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">报告编号:</text>
            <text class="info-value">#{{currentRecord.id}}</text>
          </view>
        </view>
      </view>
    </view>
  </t-popup>
</view> 