<!--records.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-section">
    <t-search 
      placeholder="搜索档案或记录" 
      bind:submit="onSearch"
      bind:change="onSearchChange"
      value="{{searchValue}}"
    />
  </view>

  <!-- 筛选栏 -->
  <view class="filter-section">
    <t-tabs 
      value="{{activeTab}}" 
      bind:change="onTabChange"
      theme="card"
    >
      <t-tab-panel label="全部档案" value="all">
        <view class="tab-content">
          <view class="record-stats">
            <text class="stats-text">共 {{totalCount}} 个档案</text>
            <text class="stats-desc">检测时间：{{lastDetectionTime}}</text>
          </view>
          
          <view class="record-list" wx:if="{{filteredRecords.length > 0}}">
            <t-cell 
              wx:for="{{filteredRecords}}" 
              wx:key="id"
              title="{{item.name}}"
              description="更新时间：{{item.updateTime}}"
              image="{{item.avatar}}"
              hover
              bindtap="onRecordClick"
              data-id="{{item.id}}"
              right-icon="chevron-right"
            >
              <view slot="note" class="record-meta">
                <t-tag 
                  theme="{{item.type === 'mine' ? 'primary' : 'default'}}" 
                  size="small"
                >
                  {{item.type === 'mine' ? '我的' : '其他'}}
                </t-tag>
              </view>
            </t-cell>
          </view>
          
          <!-- 空状态 -->
          <t-empty 
            wx:if="{{filteredRecords.length === 0}}"
            description="暂无档案记录"
          />
        </view>
      </t-tab-panel>
      
      <t-tab-panel label="我的档案" value="mine">
        <view class="tab-content">
          <view class="record-list" wx:if="{{myRecords.length > 0}}">
            <t-cell 
              wx:for="{{myRecords}}" 
              wx:key="id"
              title="{{item.name}}"
              description="更新时间：{{item.updateTime}}"
              image="{{item.avatar}}"
              hover
              bindtap="onRecordClick"
              data-id="{{item.id}}"
              right-icon="chevron-right"
            >
              <view slot="note" class="record-meta">
                <t-tag theme="primary" size="small">我的</t-tag>
              </view>
            </t-cell>
          </view>
          
          <!-- 空状态 -->
          <t-empty 
            wx:if="{{myRecords.length === 0}}"
            description="暂无我的档案"
          />
        </view>
      </t-tab-panel>
      
      <t-tab-panel label="其他档案" value="others">
        <view class="tab-content">
          <view class="record-list" wx:if="{{otherRecords.length > 0}}">
            <t-cell 
              wx:for="{{otherRecords}}" 
              wx:key="id"
              title="{{item.name}}"
              description="更新时间：{{item.updateTime}}"
              image="{{item.avatar}}"
              hover
              bindtap="onRecordClick"
              data-id="{{item.id}}"
              right-icon="chevron-right"
            >
              <view slot="note" class="record-meta">
                <t-tag theme="default" size="small">其他</t-tag>
              </view>
            </t-cell>
          </view>
          
          <!-- 空状态 -->
          <t-empty 
            wx:if="{{otherRecords.length === 0}}"
            description="暂无其他档案"
          />
        </view>
      </t-tab-panel>
    </t-tabs>
  </view>
</view> 